namespace AmGit
{
    // CLI entry point. Supports:
    //
    //     am-git clone <url> [target-dir]
    //     am-git hash-object [-w] <file>
    //
    // The target dir for `clone` defaults to the last segment of the
    // URL with any trailing `.git` stripped — same convention as
    // upstream git.
    class Program
    {
        import Am.Lang
        import Am.IO
        import Am.Git
        import Am.Collections

        static fun main(args: String[]) {
            if (args.length() == 0UI) {
                Program.printUsage()
                return
            }
            var command = args[0UI]
            if (command == "clone") {
                Program.runClone(args)
            } else if (command == "hash-object") {
                Program.runHashObject(args)
            } else if (command == "whoami") {
                Program.runWhoAmI(args)
            } else if (command == "head") {
                Program.runHead(args)
            } else if (command == "write-tree") {
                Program.runWriteTree(args)
            } else if (command == "commit-tree") {
                Program.runCommitTree(args)
            } else if (command == "commit") {
                Program.runCommit(args)
            } else if (command == "cat-file") {
                Program.runCatFile(args)
            } else if (command == "rev-list-objects") {
                Program.runRevListObjects(args)
            } else if (command == "pack-objects") {
                Program.runPackObjects(args)
            } else if (command == "build-push-body") {
                Program.runBuildPushBody(args)
            } else if (command == "auth-header") {
                Program.runAuthHeader(args)
            } else if (command == "push") {
                Program.runPush(args)
            } else if (command == "fetch") {
                Program.runFetch(args)
            } else if (command == "log") {
                Program.runLog(args)
            } else if (command == "branch") {
                Program.runBranch(args)
            } else if (command == "tag") {
                Program.runTag(args)
            } else if (command == "checkout") {
                Program.runCheckout(args)
            } else if (command == "status") {
                Program.runStatus(args)
            } else if (command == "add") {
                Program.runAdd(args)
            } else if (command == "rm") {
                Program.runRm(args)
            } else if (command == "mv") {
                Program.runMv(args)
            } else if (command == "pull") {
                Program.runPull(args)
            } else if (command == "merge-base") {
                Program.runMergeBase(args)
            } else if (command == "ls-stages") {
                Program.runLsStages(args)
            } else if (command == "merge-plan") {
                Program.runMergePlan(args)
            } else if (command == "merge") {
                Program.runMerge(args)
            } else if (command == "reset") {
                Program.runReset(args)
            } else if (command == "diff") {
                Program.runDiff(args)
            } else if (command == "show") {
                Program.runShow(args)
            } else if (command == "rebase") {
                Program.runRebase(args)
            } else if (command == "cherry-pick") {
                Program.runCherryPick(args)
            } else if (command == "revert") {
                Program.runRevert(args)
            } else if (command == "init") {
                Program.runInit(args)
            } else if (command == "config") {
                Program.runConfig(args)
            } else if (command == "help" || command == "--help" || command == "-h") {
                Program.printUsage()
            } else if (command == "version" || command == "--version") {
                "am-git 0.1.0".println()
            } else {
                ("am-git: unknown command '" + command + "'").println()
                Program.printUsage()
            }
        }

        // `am-git init [<directory>]` — scaffold a fresh `.git/`
        // skeleton at the given path (defaults to cwd). Reinit-safe:
        // if `.git/` already exists, ensures the standard subdirs
        // are present without touching anything that's already there
        // — same behaviour as real `git init`.
        //
        // Minimal layout we lay down:
        //
        //   .git/HEAD             "ref: refs/heads/main\n"
        //                         (only written if missing — don't
        //                         clobber an existing branch)
        //   .git/config           tiny [core] section
        //                         (only written if missing)
        //   .git/objects/         empty
        //   .git/objects/pack/    empty
        //   .git/refs/heads/      empty
        //   .git/refs/tags/       empty
        //   .git/info/            empty
        //
        // Default branch is hardcoded to `main` for v1 — no
        // `init.defaultBranch` config plumbing yet. Pass `-b <name>`
        // later when we wire `am-git config`.
        // `am-git config`                                     — list everything
        // `am-git config --list`                              — list everything (explicit)
        // `am-git config <key>`                               — print value (empty exit on miss)
        // `am-git config <key> <value>`                       — set / overwrite
        // `am-git config --unset <key>`                       — remove
        //
        // Operates on `.git/config` only — no user / system / `--global`
        // scope yet. Output of `--list` is `<key>=<value>` per line,
        // matching the column-less form `git config --list` emits.
        //
        // Writes go through `GitConfig.write`, which rewrites the
        // file in canonical layout (sections sorted alphabetically,
        // comments / original ordering not preserved). Hand-editing
        // and `am-git config` aren't recommended in the same file
        // unless you're fine with losing your formatting.
        private static fun runConfig(args: String[]) {
            try {
                if (args.length() == 1UI) {
                    Program.configList()
                    return
                }
                var first = args[1UI]
                if (first == "--list") {
                    Program.configList()
                    return
                }
                if (first == "--unset") {
                    if (args.length() != 3UI) {
                        "usage: am-git config --unset <key>".println()
                        return
                    }
                    Program.configUnset(args[2UI])
                    return
                }
                // Reject any other flag — keeps the door open for
                // `--global` etc. without silently accepting them.
                if (first.startsWith("--")) {
                    ("config: unrecognised flag '" + first + "'").println()
                    return
                }
                if (args.length() == 2UI) {
                    Program.configGet(first)
                    return
                }
                if (args.length() == 3UI) {
                    Program.configSet(first, args[2UI])
                    return
                }
                "usage: am-git config [--list | --unset <key> | <key> [<value>]]".println()
            } catch (ex: Exception) {
                ("config: " + ex.message).println()
            }
        }

        private static fun configList() {
            var cfg = GitConfig.read(".git")
            var keys = cfg.keys()
            // Sort bytewise for stable output — same rule as
            // GitConfig.write uses internally.
            Program.sortStringsBytewise(keys)
            var i = 0
            while (i < keys.getSize()) {
                var k = keys.get(i)
                (k + "=" + cfg.getValue(k)).println()
                i = i + 1
            }
        }

        private static fun configGet(key: String) {
            var cfg = GitConfig.read(".git")
            var v = cfg.getValue(key)
            if (v != null) {
                v.println()
            }
            // No value = silent + empty exit, same as `git config`.
        }

        private static fun configSet(key: String, value: String) {
            if (!Program.isValidConfigKey(key)) {
                ("config: invalid key '" + key +
                    "' — keys must be `<section>.<key>` or `<section>.<sub>.<key>`").println()
                return
            }
            var cfg = GitConfig.read(".git")
            cfg.setValue(key, value)
            cfg.write(".git")
        }

        private static fun configUnset(key: String) {
            var cfg = GitConfig.read(".git")
            if (!cfg.unsetValue(key)) {
                ("config: key '" + key + "' not set").println()
                return
            }
            cfg.write(".git")
        }

        // A key needs at least one `.` (separating section from field
        // name). We don't enforce the alnum + `-` restriction on the
        // section name yet — real git is strict here, but for v1 we
        // trust the user.
        private static fun isValidConfigKey(key: String): Bool {
            return key != null && key.length() > 0 && key.indexOf(".") > 0
        }

        private static fun runInit(args: String[]) {
            try {
                var target = "."
                if (args.length() >= 2UI) {
                    target = args[1UI]
                }
                Repository.ensureDir(target)
                var gitDir = target + "/.git"
                var alreadyExisted = new File(gitDir).exists()

                // Idempotent dir creation. ensureDir is a no-op when
                // the path already exists, so re-running init is
                // safe even on a non-fresh repo.
                Repository.ensureDir(gitDir)
                Repository.ensureDir(gitDir + "/objects")
                Repository.ensureDir(gitDir + "/objects/pack")
                Repository.ensureDir(gitDir + "/refs")
                Repository.ensureDir(gitDir + "/refs/heads")
                Repository.ensureDir(gitDir + "/refs/tags")
                Repository.ensureDir(gitDir + "/info")

                // HEAD: only write when missing. Otherwise we'd
                // silently move someone's checked-out branch to
                // `main` on a re-init, which is the kind of papercut
                // real git is careful to avoid.
                var headPath = gitDir + "/HEAD"
                if (!new File(headPath).exists()) {
                    "ref: refs/heads/main\n".writeToFile(headPath)
                }

                // Config: same "only if missing" rule. The minimal
                // INI is enough that `git fsck` is happy; user-level
                // settings get added later via `am-git config`.
                var configPath = gitDir + "/config"
                if (!new File(configPath).exists()) {
                    ("[core]\n" +
                     "\trepositoryformatversion = 0\n" +
                     "\tfilemode = false\n" +
                     "\tbare = false\n").writeToFile(configPath)
                }

                var verb = "Initialized"
                if (alreadyExisted) {
                    verb = "Reinitialized existing"
                }
                ("" + verb + " empty am-git repository in " + gitDir).println()
            } catch (ex: Exception) {
                ("init: " + ex.message).println()
            }
        }

        private static fun runClone(args: String[]) {
            if (args.length() < 2UI) {
                "usage: am-git clone <url> [target-dir]".println()
                return
            }
            try {
                var url = args[1UI]
                var target = ""
                if (args.length() >= 3UI) {
                    target = args[2UI]
                } else {
                    var parsed = GitUrl.parse(url)
                    target = parsed.repositoryName()
                }
                if (target.length() == 0) {
                    target = "repo"
                }
                CloneClient.clone(url, target)
            } catch (ex: Exception) {
                ("clone failed: " + ex.message).println()
            }
        }

        // Mirrors `git hash-object [-w] <file>`. Without `-w` just
        // prints the SHA-1 the file would have if it were a blob;
        // with `-w` also writes it as a loose object under ./.git/
        // (caller's cwd is assumed to be a working tree root for
        // now — no upward search yet).
        private static fun runHashObject(args: String[]) {
            var write = false
            var fileArgIdx = 1UI
            if (args.length() >= 3UI && args[1UI] == "-w") {
                write = true
                fileArgIdx = 2UI
            }
            if (args.length() <= fileArgIdx) {
                "usage: am-git hash-object [-w] <file>".println()
                return
            }
            try {
                var path = args[fileArgIdx]
                var file = new File(path)
                if (!file.exists()) {
                    ("hash-object: " + path + " does not exist").println()
                    return
                }
                var stream = new FileStream(file, FileAccess.readOnly)
                var content = stream.readAll()
                if (write) {
                    var writer = new LooseObjectWriter(".git")
                    writer.write("blob", content).println()
                } else {
                    PackObject.computeSha("blob", content).println()
                }
            } catch (ex: Exception) {
                ("hash-object failed: " + ex.message).println()
            }
        }

        // Diagnostic: print what identity am-git would commit as.
        // Resolves Identity from env vars and prints author/committer
        // lines as they'd appear in a commit object right now. Useful
        // for confirming AM_GIT_USER_NAME/EMAIL are picked up before
        // running a real commit.
        private static fun runWhoAmI(args: String[]) {
            var now = new DateTime()
            var author = Identity.loadAuthor()
            var committer = Identity.loadCommitter()
            if (author == null) {
                "author: <unset — set GIT_AUTHOR_NAME/EMAIL or AM_GIT_USER_NAME/EMAIL>".println()
            } else {
                ("author    " + author.formatLine(now)).println()
            }
            if (committer == null) {
                "committer: <unset — set GIT_COMMITTER_NAME/EMAIL or AM_GIT_USER_NAME/EMAIL>".println()
            } else {
                ("committer " + committer.formatLine(now)).println()
            }
        }

        // Diagnostic: read `.git/HEAD` (and the branch ref it points
        // at) and print the resolved state. Mirrors `git rev-parse
        // HEAD` + `git symbolic-ref HEAD` rolled together. Runs
        // against `./.git` in the cwd.
        private static fun runHead(args: String[]) {
            try {
                var info = HeadReader.read(".git")
                if (info.detached) {
                    ("detached HEAD at " + info.commitSha).println()
                } else if (info.isInitial()) {
                    ("on branch " + info.branch + " (unborn — no commits yet)").println()
                } else {
                    ("on branch " + info.branch + " at " + info.commitSha).println()
                }
            } catch (ex: Exception) {
                ("head: " + ex.message).println()
            }
        }

        // Diagnostic: walk the working tree (cwd) and write blobs +
        // trees as loose objects under ./.git/. Prints the root tree
        // SHA. Mirrors `git write-tree` — useful to confirm our
        // TreeBuilder's SHA matches what real git produces for the
        // same on-disk state.
        private static fun runWriteTree(args: String[]) {
            try {
                var writer = new LooseObjectWriter(".git")
                var builder = new TreeBuilder(".", writer)
                builder.build().println()
            } catch (ex: Exception) {
                ("write-tree: " + ex.message).println()
            }
        }

        // Mirrors `git commit-tree <tree> [-p <parent>] -m <message>`.
        // Reads identity from env (see Identity.loadAuthor /
        // loadCommitter) and optionally pinned timestamps via
        // GIT_AUTHOR_DATE / GIT_COMMITTER_DATE — same names real git
        // uses, same `<unix-seconds> <±HHMM>` format. Writes the
        // commit as a loose object under ./.git/ and prints its SHA.
        private static fun runCommitTree(args: String[]) {
            try {
                if (args.length() < 2UI) {
                    "usage: am-git commit-tree <tree-sha> [-p <parent-sha>] -m <message>".println()
                    return
                }
                var treeSha = args[1UI]
                var parentSha: String? = null
                var message: String? = null
                var i = 2UI
                while (i < args.length()) {
                    var a = args[i]
                    if (a == "-p" && i + 1UI < args.length()) {
                        parentSha = args[i + 1UI]
                        i = i + 2UI
                    } else if (a == "-m" && i + 1UI < args.length()) {
                        message = args[i + 1UI]
                        i = i + 2UI
                    } else {
                        ("commit-tree: unrecognised arg '" + a + "'").println()
                        return
                    }
                }
                if (message == null) {
                    "commit-tree: -m <message> is required".println()
                    return
                }

                var author = Identity.loadAuthor()
                var committer = Identity.loadCommitter()
                if (author == null || committer == null) {
                    "commit-tree: identity not configured (set AM_GIT_USER_NAME and AM_GIT_USER_EMAIL)".println()
                    return
                }
                var authorTime = Identity.loadAuthorDate()
                if (authorTime == null) {
                    authorTime = new DateTime()
                }
                var committerTime = Identity.loadCommitterDate()
                if (committerTime == null) {
                    committerTime = new DateTime()
                }

                var writer = new LooseObjectWriter(".git")
                var commitWriter = new CommitWriter(writer)
                commitWriter.write(treeSha, parentSha,
                                    author, authorTime,
                                    committer, committerTime,
                                    message).println()
            } catch (ex: Exception) {
                ("commit-tree: " + ex.message).println()
            }
        }

        // The user-facing commit. Wraps the four primitives we built
        // in steps 1-5:
        //
        //   1. HeadReader.read       → current branch + parent SHA
        //   2. TreeBuilder.build     → root tree SHA from cwd
        //   3. CommitWriter.write    → new commit SHA
        //   4. write ref/HEAD        → atomic move-forward of the
        //                              branch (or detached HEAD)
        //
        // v1 differences from real `git commit`:
        //
        //   * No staging — always commits the live working tree state
        //     against HEAD's parent. No `git add` step required.
        //   * No "nothing to commit" detection — we don't compare the
        //     new tree's SHA against HEAD's tree. If the working tree
        //     is unchanged you'll just get an empty-delta commit
        //     (legal git object, semantically equivalent to passing
        //     `--allow-empty` to real git). Catching this needs a
        //     loose-object reader, which isn't wired yet.
        //   * No commit hooks, no editor invocation, no GPG signing.
        //
        // Output format mirrors `git commit`'s one-liner:
        //   `[branch <shortsha>] <first line>`
        //   `[branch (root-commit) <shortsha>] <first line>`  (initial)
        //   `[detached HEAD <shortsha>] <first line>`         (detached)
        private static fun runCommit(args: String[]) {
            try {
                var message: String? = null
                var i = 1UI
                while (i < args.length()) {
                    var a = args[i]
                    if (a == "-m" && i + 1UI < args.length()) {
                        message = args[i + 1UI]
                        i = i + 2UI
                    } else {
                        ("commit: unrecognised arg '" + a + "'").println()
                        return
                    }
                }
                if (message == null) {
                    "usage: am-git commit -m <message>".println()
                    return
                }

                // Refuse to commit while a rebase is in flight —
                // a plain commit would put a commit at HEAD without
                // advancing the rebase's todo, leaving a half-rebased
                // state. The user should `am-git rebase --continue`
                // or `--abort`.
                if (RebaseState.isInProgress(".git")) {
                    "commit: rebase in progress — use `am-git rebase --continue` or `--abort`".println()
                    return
                }
                // Same shape for cherry-pick: a plain commit would
                // bypass the author + message preservation that
                // --continue does for us.
                if (Program.cherryPickInProgress()) {
                    "commit: cherry-pick in progress — use `am-git cherry-pick --continue` or `--abort`".println()
                    return
                }
                if (Program.revertInProgress()) {
                    "commit: revert in progress — use `am-git revert --continue` or `--abort`".println()
                    return
                }

                var head = HeadReader.read(".git")

                var author = Identity.loadAuthor()
                var committer = Identity.loadCommitter()
                if (author == null || committer == null) {
                    "commit: identity not configured (set AM_GIT_USER_NAME and AM_GIT_USER_EMAIL)".println()
                    return
                }
                var authorTime = Identity.loadAuthorDate()
                if (authorTime == null) {
                    authorTime = new DateTime()
                }
                var committerTime = Identity.loadCommitterDate()
                if (committerTime == null) {
                    committerTime = new DateTime()
                }

                var writer = new LooseObjectWriter(".git")
                // Prefer the index when one exists — real git semantics.
                // No index file → fall back to walking the working
                // tree, preserving am-git's pre-index "commit
                // everything" behaviour for repos that haven't run
                // `am-git add` yet.
                var treeSha: String? = null
                var indexFile = new File(".git/index")
                var idxForUnmergedCheck: GitIndex? = null
                if (indexFile.exists()) {
                    var idx = GitIndex.read(".git")
                    idxForUnmergedCheck = idx
                    if (idx.entries.getSize() == 0) {
                        "commit: nothing to commit (index is empty)".println()
                        return
                    }
                    // Refuse to commit while the index records an
                    // unresolved merge — same precondition as real
                    // git ("Committing is not possible because you
                    // have unmerged files").
                    if (idx.hasUnmerged()) {
                        "commit: unresolved merge conflicts — fix the listed paths and `am-git add` them first".println()
                        var ui = 0
                        while (ui < idx.entries.getSize()) {
                            var ue = idx.entries.get(ui)
                            if (ue.stage() != 0) {
                                ("  " + ue.path + " (stage " + ue.stage().toString() + ")").println()
                            }
                            ui = ui + 1
                        }
                        return
                    }
                    treeSha = IndexTreeBuilder.build(idx, writer)
                } else {
                    treeSha = new TreeBuilder(".", writer).build()
                }

                // Merge-commit detection: if `.git/MERGE_HEAD` is
                // present we're finalising a 3-way merge `am-git
                // merge` left half-done. The file's contents are the
                // SHA of the second parent.
                var parents = List<String>.newList<String>()
                if (head.commitSha != null) {
                    parents.add(head.commitSha)
                }
                var mergeHeadFile = new File(".git/MERGE_HEAD")
                var inMergeFinalisation = mergeHeadFile.exists()
                if (inMergeFinalisation) {
                    var rawMergeHead = String.readFromFile(".git/MERGE_HEAD")
                    parents.add(Program.trim(rawMergeHead))
                }

                var commitSha = new CommitWriter(writer).writeMulti(
                    treeSha, parents,
                    author, authorTime,
                    committer, committerTime,
                    message)

                // Move the ref forward. For a normal branch we
                // overwrite `.git/refs/heads/<branch>` (creating it
                // on the unborn-branch path); for detached HEAD we
                // overwrite `.git/HEAD` itself.
                if (head.detached) {
                    (commitSha + "\n").writeToFile(".git/HEAD")
                } else {
                    var refPath = ".git/refs/heads/" + head.branch
                    Repository.ensureParentDir(refPath)
                    (commitSha + "\n").writeToFile(refPath)
                }

                // Re-seed the index from the new tree. After an
                // index-based commit it's essentially a no-op (entries
                // already match the committed SHAs), but after a
                // worktree-based commit this populates the index for
                // the first time so subsequent `add`s don't see a
                // confusing "everything deleted" status.
                //
                // We read the tree from `writer.written` rather than a
                // fresh `ObjectStore` — same-process write→read of a
                // loose object isn't reliable on AmigaOS, and we
                // already have every object we just wrote in memory.
                GitIndex.fromTreeMap(treeSha, writer.written).write(".git")

                // If this was a merge-commit finalisation, the merge
                // is done — clear the two metadata files so the next
                // commit isn't accidentally promoted into a merge.
                if (inMergeFinalisation) {
                    Program.deleteIfExists(".git/MERGE_HEAD")
                    Program.deleteIfExists(".git/MERGE_MSG")
                }

                // Summary line. `firstLine` is the message up to the
                // first `\n` (matches `git commit`'s output convention).
                var shortSha = commitSha.substring(0UI, 7UI)
                var firstLine = message
                var nl = message.indexOf("\n")
                if (nl >= 0) {
                    firstLine = message.substring(0UI, nl.toUInt())
                }
                var rootMarker = ""
                if (head.isInitial()) {
                    rootMarker = " (root-commit)"
                }
                var branchLabel = "detached HEAD"
                if (!head.detached) {
                    branchLabel = head.branch
                }
                ("[" + branchLabel + rootMarker + " " + shortSha + "] " + firstLine).println()
            } catch (ex: Exception) {
                "commit: failed".println()
                ex.printWithStackTrace()
            }
        }

        // Mirrors `git cat-file -p <sha>` (pretty-print object content)
        // and `git cat-file -t <sha>` (type). Reads from `./.git/objects/`
        // via LooseObjectReader. Useful for confirming our writes/reads
        // round-trip with what real git would emit.
        private static fun runCatFile(args: String[]) {
            try {
                if (args.length() < 3UI) {
                    "usage: am-git cat-file (-p|-t) <sha>".println()
                    return
                }
                var flag = args[1UI]
                var sha = args[2UI]
                var reader = new LooseObjectReader(".git")
                var obj = reader.read(sha)
                if (flag == "-t") {
                    obj.typeName().println()
                } else if (flag == "-p") {
                    // Most objects are text — `String.fromBytes(...,
                    // "UTF-8").print()` works fine for commits and
                    // trees-as-debug-output. Trees actually contain
                    // raw 20-byte SHAs after each name's NUL, so the
                    // bytes-to-UTF8 round-trip would mangle them.
                    // For now we print as if UTF-8; trees will look
                    // garbled but commits / blobs will be readable —
                    // good enough for round-trip diagnostics.
                    String.fromBytes(obj.content, "UTF-8").print()
                } else {
                    ("cat-file: unknown flag '" + flag + "'").println()
                }
            } catch (ex: Exception) {
                ("cat-file: " + ex.message).println()
            }
        }

        // Diagnostic for ObjectWalker. Mirrors a subset of
        // `git rev-list --objects <new> ^<have>` — prints every SHA
        // reachable from <new> that isn't reachable from <have>.
        // Useful for cross-checking the walk against real git
        // before we feed the result into PackWriter.
        //
        //   am-git rev-list-objects <new-sha> [<have-sha>]
        //
        // If <have-sha> is omitted, treats it as 40 zeros (every
        // reachable object).
        private static fun runRevListObjects(args: String[]) {
            try {
                if (args.length() < 2UI) {
                    "usage: am-git rev-list-objects <new-sha> [<have-sha>]".println()
                    return
                }
                var newSha = args[1UI]
                var haveSha: String = "0000000000000000000000000000000000000000"
                if (args.length() >= 3UI) {
                    haveSha = args[2UI]
                }
                var store = new ObjectStore(".git")
                var walker = new ObjectWalker(store)
                var shas = walker.collect(newSha, haveSha)
                var i = 0
                while (i < shas.getSize()) {
                    shas.get(i).println()
                    i = i + 1
                }
            } catch (ex: Exception) {
                ("rev-list-objects: " + ex.message).println()
            }
        }

        // Build a v2 packfile containing every object reachable from
        // <new-sha> that isn't reachable from <have-sha>. Writes the
        // pack bytes to <output-pack> — pipe through `git index-pack
        // --stdin --keep` to verify the pack is well-formed and the
        // contained objects match git's view of those SHAs.
        private static fun runPackObjects(args: String[]) {
            try {
                if (args.length() < 3UI) {
                    "usage: am-git pack-objects <output-pack> <new-sha> [<have-sha>]".println()
                    return
                }
                var outPath = args[1UI]
                var newSha = args[2UI]
                var haveSha: String = "0000000000000000000000000000000000000000"
                if (args.length() >= 4UI) {
                    haveSha = args[3UI]
                }
                var store = new ObjectStore(".git")
                var walker = new ObjectWalker(store)
                var shas = walker.collect(newSha, haveSha)
                ("Walking " + shas.getSize().toString() + " objects").println()

                var objects = List<PackObject>.newList<PackObject>()
                var i = 0
                while (i < shas.getSize()) {
                    var sha = shas.get(i)
                    if (!store.has(sha)) {
                        throw new Exception("missing object: " + sha)
                    }
                    objects.add(store.read(sha))
                    i = i + 1
                }

                var pack = PackWriter.writePack(objects)
                Repository.writeBytes(outPath, pack)
                ("Wrote " + pack.length().toString() + " bytes to " + outPath).println()
            } catch (ex: Exception) {
                ("pack-objects: " + ex.message).println()
            }
        }

        // Build a receive-pack request body for a single ref update
        // and write it to <output>. Pipe through `git receive-pack
        // <bare-repo>` to confirm the server accepts our framing +
        // packfile end-to-end.
        //
        //     am-git build-push-body <output> <old-sha> <new-sha> <ref>
        //
        // Uses <ref>'s walk: every object reachable from <new-sha> but
        // not from <old-sha>. Pass 40 zeros for old-sha on a fresh ref.
        private static fun runBuildPushBody(args: String[]) {
            try {
                if (args.length() < 5UI) {
                    "usage: am-git build-push-body <output> <old-sha> <new-sha> <refname>".println()
                    return
                }
                var outPath = args[1UI]
                var oldSha = args[2UI]
                var newSha = args[3UI]
                var refName = args[4UI]

                var store = new ObjectStore(".git")
                var walker = new ObjectWalker(store)
                var shas = walker.collect(newSha, oldSha)
                ("Walking " + shas.getSize().toString() + " objects").println()

                var objects = List<PackObject>.newList<PackObject>()
                var i = 0
                while (i < shas.getSize()) {
                    var sha = shas.get(i)
                    objects.add(store.read(sha))
                    i = i + 1
                }

                var pack = PackWriter.writePack(objects)
                var updates = List<RefUpdate>.newList<RefUpdate>()
                updates.add(new RefUpdate(oldSha, newSha, refName))

                var body = ReceivePackRequest.build(updates, pack)
                Repository.writeBytes(outPath, body)
                ("Wrote " + body.length().toString() + " bytes to " + outPath).println()
            } catch (ex: Exception) {
                ("build-push-body: " + ex.message).println()
            }
        }

        // Print the Authorization header that would be sent for the
        // current AM_GIT_USERNAME / AM_GIT_PASSWORD env vars. Mostly
        // a debugging aid — verify the encoding against `echo -n
        // "$AM_GIT_USERNAME:$AM_GIT_PASSWORD" | base64`. Pass an
        // explicit `<user> <pass>` pair to avoid relying on env.
        private static fun runAuthHeader(args: String[]) {
            try {
                var value: String? = null
                if (args.length() >= 3UI) {
                    value = BasicAuth.headerValue(args[1UI], args[2UI])
                } else {
                    value = BasicAuth.fromEnv()
                }
                if (value == null) {
                    "auth-header: AM_GIT_USERNAME and AM_GIT_PASSWORD must both be set".println()
                    return
                }
                value.println()
            } catch (ex: Exception) {
                ("auth-header: " + ex.message).println()
            }
        }

        // Fast-forward-only pull. Either form works:
        //
        //   am-git pull                     (URL from .git/config, branch from HEAD)
        //   am-git pull <url>               (branch from HEAD)
        //   am-git pull <url> <branch>      (both explicit)
        //
        // Bails on non-fast-forward — no merge / rebase machinery yet.
        private static fun runPull(args: String[]) {
            try {
                var remoteUrl: String? = null
                var branch: String? = null
                if (args.length() >= 2UI) {
                    remoteUrl = args[1UI]
                }
                if (args.length() >= 3UI) {
                    branch = args[2UI]
                }
                PullClient.pull(".git", ".", remoteUrl, branch, "origin")
            } catch (ex: Exception) {
                ("pull: " + ex.message).println()
            }
        }

        // `am-git merge-base <a> <b>` — print the SHA of the lowest
        // common ancestor of two commits. Each arg is either a 40-char
        // hex SHA or a local branch name (resolved against
        // .git/refs/heads/). Prints nothing and exits silently when
        // the commits share no history (matches real git, which uses
        // a non-zero exit code; we don't have one wired up yet).
        private static fun runMergeBase(args: String[]) {
            try {
                if (args.length() != 3UI) {
                    "usage: am-git merge-base <commit-a> <commit-b>".println()
                    return
                }
                var aSha = Program.resolveCommitish(args[1UI])
                var bSha = Program.resolveCommitish(args[2UI])
                if (aSha == null) {
                    ("merge-base: cannot resolve '" + args[1UI] + "'").println()
                    return
                }
                if (bSha == null) {
                    ("merge-base: cannot resolve '" + args[2UI] + "'").println()
                    return
                }
                var store = new ObjectStore(".git")
                var baseSha = MergeBase.find(aSha, bSha, store)
                if (baseSha != null) {
                    baseSha.println()
                }
            } catch (ex: Exception) {
                ("merge-base: " + ex.message).println()
            }
        }

        // `am-git merge-plan <ours> <theirs>` — print the 3-way
        // classification of every changed path between two commits,
        // using their common ancestor as the base. Dry-run: nothing
        // is written. Used to validate the merge classifier on
        // realistic histories before piece 3 wires up the actual
        // applier.
        //
        // Output: one line per changed path:
        //   <outcome>\t<path>\t<ours-sha>\t<theirs-sha>\t<base-sha>
        // Unchanged paths are omitted to keep the output focused.
        private static fun runMergePlan(args: String[]) {
            try {
                if (args.length() != 3UI) {
                    "usage: am-git merge-plan <ours-commit> <theirs-commit>".println()
                    return
                }
                var oursSha = Program.resolveCommitish(args[1UI])
                var theirsSha = Program.resolveCommitish(args[2UI])
                if (oursSha == null) {
                    ("merge-plan: cannot resolve '" + args[1UI] + "'").println()
                    return
                }
                if (theirsSha == null) {
                    ("merge-plan: cannot resolve '" + args[2UI] + "'").println()
                    return
                }
                var store = new ObjectStore(".git")
                var baseSha = MergeBase.find(oursSha, theirsSha, store)
                if (baseSha == null) {
                    "merge-plan: no common ancestor (unrelated histories)".println()
                    return
                }
                var oursTree = Program.commitTreeSha(oursSha, store)
                var theirsTree = Program.commitTreeSha(theirsSha, store)
                var baseTree = Program.commitTreeSha(baseSha, store)
                ("# base " + baseSha).println()
                ("# ours " + oursSha + " (tree " + oursTree + ")").println()
                ("# theirs " + theirsSha + " (tree " + theirsTree + ")").println()
                var plan = MergePlan.compute(baseTree, oursTree, theirsTree, store)
                var conflicts = 0
                var i = 0
                while (i < plan.getSize()) {
                    var e = plan.get(i)
                    if (e.outcome != MergePlan.outcomeUnchanged) {
                        var line = MergePlan.outcomeName(e.outcome) + "\t" + e.path +
                                   "\t" + Program.shaOrDash(e.ours) +
                                   "\t" + Program.shaOrDash(e.theirs) +
                                   "\t" + Program.shaOrDash(e.baseFile)
                        line.println()
                        if (e.outcome >= MergePlan.outcomeConflictBothModified) {
                            conflicts = conflicts + 1
                        }
                    }
                    i = i + 1
                }
                if (conflicts > 0) {
                    ("# " + conflicts.toString() + " conflict(s)").println()
                } else {
                    "# no conflicts".println()
                }
            } catch (ex: Exception) {
                ("merge-plan: " + ex.message).println()
            }
        }

        // Read a commit's root-tree SHA. Throws if the commit isn't in
        // the store — the merge-plan caller bails on that case loud
        // and clear rather than silently merging against an empty tree.
        private static fun commitTreeSha(commitSha: String, store: ObjectStore): String? {
            if (!store.has(commitSha)) {
                throw new Exception("commit not found in object store: " + commitSha)
            }
            var obj = store.read(commitSha)
            if (obj.typeCode != 1) {
                throw new Exception(commitSha + " is not a commit")
            }
            return WorkTree.extractRootTreeSha(obj.content)
        }

        // "(absent)" → "-" so the columnar output stays readable.
        private static fun shaOrDash(f: MergeFile): String? {
            if (f == null) {
                return "-"
            }
            return f.sha
        }

        // `am-git merge <branch>` — merge the named branch into the
        // current branch. Three resolution paths:
        //
        //   1. `branch` is an ancestor of HEAD → "already up to date",
        //      do nothing.
        //   2. HEAD is an ancestor of `branch` → fast-forward: move
        //      the branch ref + materialise the new working tree.
        //      No merge commit; same as real git's default ff-on-ff.
        //   3. Divergent histories → 3-way merge:
        //      - compute MergePlan
        //      - apply it (writes workdir + index stages)
        //      - if no conflicts → create a 2-parent merge commit,
        //        advance HEAD, clear MERGE_HEAD
        //      - if conflicts → write `.git/MERGE_HEAD` +
        //        `.git/MERGE_MSG`, leave the workdir in conflict
        //        state, print the conflict list. The user resolves,
        //        runs `am-git add <file>...`, then `am-git commit`
        //        to finalise.
        //
        // Refuses to merge from detached HEAD (we don't have an
        // anonymous ref to advance) and from an unborn branch (no
        // HEAD commit to merge with).
        private static fun runMerge(args: String[]) {
            try {
                if (args.length() != 2UI) {
                    "usage: am-git merge <branch>".println()
                    return
                }
                var head = HeadReader.read(".git")
                if (head.detached) {
                    "merge: cannot merge from detached HEAD".println()
                    return
                }
                if (head.commitSha == null) {
                    "merge: current branch has no commits yet — nothing to merge into".println()
                    return
                }

                var theirsName = args[1UI]
                var theirsSha = Program.resolveCommitish(theirsName)
                if (theirsSha == null) {
                    ("merge: cannot resolve '" + theirsName + "'").println()
                    return
                }
                var oursSha = head.commitSha

                var store = new ObjectStore(".git")
                var baseSha = MergeBase.find(oursSha, theirsSha, store)
                if (baseSha == null) {
                    "merge: refusing to merge unrelated histories".println()
                    return
                }

                // Case 1: nothing to do.
                if (baseSha == theirsSha) {
                    "Already up to date.".println()
                    return
                }

                // Case 2: fast-forward.
                if (baseSha == oursSha) {
                    Program.fastForwardMerge(head, theirsSha, theirsName)
                    return
                }

                // Case 3: real 3-way merge.
                Program.threeWayMerge(head, oursSha, theirsSha, baseSha, theirsName, store)
            } catch (ex: Exception) {
                "merge: failed".println()
                ex.printWithStackTrace()
            }
        }

        // Advance the current branch ref to the merged-in commit and
        // materialise its working tree. No merge commit — the merge
        // is fast-forwardable.
        private static fun fastForwardMerge(head: HeadInfo, theirsSha: String,
                                             theirsName: String) {
            var refPath = ".git/refs/heads/" + head.branch
            Repository.ensureParentDir(refPath)
            (theirsSha + "\n").writeToFile(refPath)

            // Checkout the new tree on top of the working tree. We
            // reuse CheckoutClient since the semantics are the same
            // as a regular branch checkout — only the ref name
            // differs, and we've already moved it.
            CheckoutClient.checkout(".git", ".", head.branch)

            ("Fast-forward: " + head.branch + " advanced to " +
                theirsSha.substring(0UI, 7UI) + " (was " +
                head.commitSha.substring(0UI, 7UI) + ")").println()
        }

        // Three-way merge. Computes the plan, applies it, and either
        // creates a merge commit (clean) or writes `MERGE_HEAD` +
        // `MERGE_MSG` and exits with the conflict list (dirty).
        private static fun threeWayMerge(head: HeadInfo, oursSha: String,
                                          theirsSha: String, baseSha: String,
                                          theirsName: String, store: ObjectStore) {
            var oursTree   = Program.commitTreeSha(oursSha, store)
            var theirsTree = Program.commitTreeSha(theirsSha, store)
            var baseTree   = Program.commitTreeSha(baseSha, store)

            var plan = MergePlan.compute(baseTree, oursTree, theirsTree, store)

            // Read or initialise the index. For a fresh worktree-only
            // commit history the index may not exist yet; the applier
            // populates it with stage-0 entries for everything.
            var idx = GitIndex.read(".git")
            var applier = new MergeApplier(".", store, idx)
            var conflicts = applier.apply(plan)
            idx.write(".git")

            if (conflicts.getSize() == 0) {
                Program.completeMergeCommit(head, oursSha, theirsSha, theirsName, store)
                return
            }

            // Conflicts: record state for `am-git commit` to pick up
            // once the user resolves. MERGE_HEAD holds the second
            // parent SHA; MERGE_MSG is a default commit message
            // including the conflict list (same shape as real git).
            (theirsSha + "\n").writeToFile(".git/MERGE_HEAD")
            Program.writeMergeMsg(theirsName, conflicts)
            ("Auto-merging produced conflicts in " +
                conflicts.getSize().toString() + " file(s):").println()
            var i = 0
            while (i < conflicts.getSize()) {
                ("  " + conflicts.get(i)).println()
                i = i + 1
            }
            "".println()
            "Resolve the conflicts, run `am-git add <file>...`, then `am-git commit`.".println()
        }

        // After a clean 3-way merge: build a fresh root tree from the
        // (now resolved) index, write a 2-parent commit, advance the
        // branch ref.
        private static fun completeMergeCommit(head: HeadInfo, oursSha: String,
                                                 theirsSha: String, theirsName: String,
                                                 store: ObjectStore) {
            var author = Identity.loadAuthor()
            var committer = Identity.loadCommitter()
            if (author == null || committer == null) {
                "merge: identity not configured (set AM_GIT_USER_NAME and AM_GIT_USER_EMAIL)".println()
                return
            }
            var authorTime = Identity.loadAuthorDate()
            if (authorTime == null)    { authorTime = new DateTime() }
            var committerTime = Identity.loadCommitterDate()
            if (committerTime == null) { committerTime = new DateTime() }

            var idx = GitIndex.read(".git")
            var writer = new LooseObjectWriter(".git")
            var treeSha = IndexTreeBuilder.build(idx, writer)

            var parents = List<String>.newList<String>()
            parents.add(oursSha)
            parents.add(theirsSha)

            var message = "Merge branch '" + theirsName + "'\n"
            var commitSha = new CommitWriter(writer).writeMulti(
                treeSha, parents, author, authorTime,
                committer, committerTime, message)

            var refPath = ".git/refs/heads/" + head.branch
            Repository.ensureParentDir(refPath)
            (commitSha + "\n").writeToFile(refPath)

            // Clean up any stale merge metadata (a previous interrupted
            // merge could have left these around — but in the clean
            // path neither file should exist).
            Program.deleteIfExists(".git/MERGE_HEAD")
            Program.deleteIfExists(".git/MERGE_MSG")

            ("Merge made by 'am-git merge' [" + head.branch + " " +
                commitSha.substring(0UI, 7UI) + "]").println()
        }

        // Default MERGE_MSG text — real git's format starts with
        // "Merge branch '<name>'" and lists the conflicting paths as
        // "# Conflicts:" comments. `am-git commit` will use this as
        // the message body if the user doesn't pass `-m`.
        private static fun writeMergeMsg(theirsName: String, conflicts: List<String>) {
            var sb = new StringBuilder()
            sb.add("Merge branch '").add(theirsName).add("'\n")
            sb.add("\n")
            sb.add("# Conflicts:\n")
            var i = 0
            while (i < conflicts.getSize()) {
                sb.add("#\t").add(conflicts.get(i)).add("\n")
                i = i + 1
            }
            sb.toString().writeToFile(".git/MERGE_MSG")
        }

        private static fun deleteIfExists(path: String) {
            var f = new File(path)
            if (f.exists()) {
                f.delete()
            }
        }

        // `am-git rebase <upstream>` — replays current-branch
        // commits on top of <upstream>, one at a time, producing N
        // new commits with new SHAs.
        //
        //     before:         upstream                 after:        upstream
        //                        |                                       |
        //          base ── C1 ── C2 ── HEAD                base ── … ── C1' ── C2' (HEAD)
        //
        // Strategy: reset HEAD to <upstream>, then for each commit
        // in the original ahead-of-upstream range (oldest first),
        // three-way merge it onto current HEAD using MergePlan +
        // MergeApplier — the same machinery as `am-git merge`, one
        // commit at a time. A clean apply produces a new commit
        // with the original commit's author + author-date + message
        // (committer is updated to "now" by `loadCommitter`).
        //
        // Conflict resolution flow:
        //   1. `am-git rebase <upstream>` starts the rebase. On
        //       conflict, it writes `.git/rebase-merge/` state files
        //       (`onto`, `orig-head`, `head-name`, `stopped-sha`,
        //       `git-rebase-todo`) and exits with the conflict list.
        //   2. The user fixes the conflicted files, runs
        //       `am-git add <file>...` to clear the conflict stages.
        //   3. `am-git rebase --continue` finalises the stopped
        //       commit from the resolved index, then processes the
        //       remaining todo. If another conflict comes up the
        //       cycle repeats.
        //   4. At any time `am-git rebase --abort` rolls HEAD,
        //       worktree, and index back to `orig-head` and clears
        //       the state.
        //
        // v1 limitations:
        //   * Linear histories only — if any commit in the range is
        //     a merge commit (multiple parents), we bail before
        //     touching anything.
        //   * No `--onto X` yet — always rebases onto <upstream>.
        //   * No `-i` interactive rebase, no squash / fixup / drop.
        private static fun runRebase(args: String[]) {
            try {
                if (args.length() < 2UI) {
                    "usage: am-git rebase <upstream> | --continue | --abort".println()
                    return
                }
                var first = args[1UI]
                if (first == "--continue") {
                    Program.runRebaseContinue()
                    return
                }
                if (first == "--abort") {
                    Program.runRebaseAbort()
                    return
                }
                // Starting a fresh rebase. Refuse if one's already
                // in progress — the user should --continue or --abort.
                if (RebaseState.isInProgress(".git")) {
                    "rebase: a rebase is already in progress. Use `--continue` or `--abort`.".println()
                    return
                }
                if (args.length() != 2UI) {
                    "usage: am-git rebase <upstream> | --continue | --abort".println()
                    return
                }
                Program.runRebaseStart(first)
            } catch (ex: Exception) {
                "rebase: failed".println()
                ex.printWithStackTrace()
            }
        }

        // Initial rebase. Resolves <upstream>, finds merge-base,
        // handles the three trivial paths (already-at / ff /
        // already-rebased), then for a real rebase: saves
        // ORIG_HEAD, resets the branch to upstream, and dispatches
        // the commit-replay loop.
        private static fun runRebaseStart(upstreamName: String) {
            var head = HeadReader.read(".git")
            if (head.detached) {
                "rebase: cannot rebase from detached HEAD".println()
                return
            }
            if (head.commitSha == null) {
                "rebase: current branch has no commits yet".println()
                return
            }
            var upstreamSha = Program.resolveCommitish(upstreamName)
            if (upstreamSha == null) {
                ("rebase: cannot resolve '" + upstreamName + "'").println()
                return
            }

            var store = new ObjectStore(".git")
            var baseSha = MergeBase.find(head.commitSha, upstreamSha, store)
            if (baseSha == null) {
                "rebase: refusing to rebase on unrelated history".println()
                return
            }

            // Already at / past upstream → nothing to do.
            if (head.commitSha == upstreamSha) {
                "Current branch already at upstream.".println()
                return
            }
            // We are an ancestor of upstream → fast-forward.
            if (baseSha == head.commitSha) {
                Program.rebaseFastForward(head, upstreamSha)
                return
            }
            // Upstream is an ancestor of HEAD → already rebased.
            if (baseSha == upstreamSha) {
                "Current branch is up to date with upstream.".println()
                return
            }

            // Collect ahead-of-upstream commits oldest-first. Linear
            // histories only — `collectLinearAhead` refuses merge
            // commits in the range and returns null in that case.
            var commits = Program.collectLinearAhead(head.commitSha, baseSha, store)
            if (commits == null) {
                return
            }

            ("Rebasing " + commits.getSize().toString() + " commit(s) onto " +
                upstreamSha.substring(0UI, 7UI)).println()

            // Save ORIG_HEAD (real git's convention) so the user can
            // do their own `am-git reset --hard ORIG_HEAD` even
            // outside the rebase machinery if they want.
            (head.commitSha + "\n").writeToFile(".git/ORIG_HEAD")

            // Reset the branch to upstream — both ref and worktree
            // + index. From here, every successful apply moves the
            // ref forward; a conflict freezes state for --continue.
            Program.moveBranchRef(head.branch, upstreamSha)
            CheckoutClient.applyCommitToWorkTree(".git", ".", upstreamSha)

            // Build the initial state — no stoppedSha yet, full todo
            // queue. The processing loop pops commits off the front
            // of todo until either the queue is empty (success) or
            // a replay hits a conflict (state written to disk).
            var state = new RebaseState()
            state.onto = upstreamSha
            state.origHead = head.commitSha
            state.headName = "refs/heads/" + head.branch
            state.stoppedSha = null
            var ti = 0
            while (ti < commits.getSize()) {
                state.todo.add(commits.get(ti).sha)
                ti = ti + 1
            }

            Program.processRebaseTodo(state, upstreamSha, store)
        }

        // Inner loop shared by `runRebaseStart` and `runRebaseContinue`.
        // Pops commits off `state.todo` one at a time, replays each
        // onto `currentHeadSha`. On conflict, saves the state (with
        // stoppedSha = the conflicting SHA) and returns. On empty
        // todo, clears state and prints success.
        private static fun processRebaseTodo(state: RebaseState,
                                              currentHeadSha: String,
                                              store: ObjectStore) {
            var head = currentHeadSha
            loop {
                if (state.todo.getSize() == 0) {
                    break
                }
                var nextSha = state.todo.get(0)
                state.todo.removeAt(0)
                if (!store.has(nextSha)) {
                    ("rebase: commit " + nextSha + " not in object store").println()
                    state.stoppedSha = nextSha
                    state.save(".git")
                    return
                }
                var obj = store.read(nextSha)
                if (obj.typeCode != 1) {
                    ("rebase: " + nextSha + " is not a commit").println()
                    return
                }
                var commit = Commit.parse(nextSha, obj.content)

                // Use the branch portion of head-name for moveBranchRef
                // — head-name is the full ref path "refs/heads/<branch>".
                var branch = Program.stripRefsHeads(state.headName)
                var replayed = Program.replayCommit(commit, head, branch, store)
                if (replayed == null) {
                    // Conflict. Persist state so `--continue` can pick
                    // up after the user resolves.
                    state.stoppedSha = nextSha
                    state.save(".git")
                    ("rebase: conflict re-applying " + nextSha.substring(0UI, 7UI) +
                        " '" + Program.firstLine(commit.message) + "'").println()
                    "  Resolve the conflicts, run `am-git add <file>...`, then `am-git rebase --continue`.".println()
                    "  Or `am-git rebase --abort` to roll back.".println()
                    return
                }
                head = replayed
                ("  applied " + nextSha.substring(0UI, 7UI) + " → " +
                    replayed.substring(0UI, 7UI) + " '" +
                    Program.firstLine(commit.message) + "'").println()
            }

            // Drained the todo cleanly. Tidy up.
            RebaseState.clear(".git")
            var branch = Program.stripRefsHeads(state.headName)
            ("Successfully rebased " + branch + " onto " +
                state.onto.substring(0UI, 7UI)).println()
        }

        // `am-git rebase --continue` — after the user has resolved
        // conflicts and `am-git add`ed the resolved files, finalise
        // the stopped commit from the index, then drain the rest of
        // the todo.
        private static fun runRebaseContinue() {
            if (!RebaseState.isInProgress(".git")) {
                "rebase: no rebase in progress".println()
                return
            }
            var state = RebaseState.load(".git")
            if (state.stoppedSha == null) {
                "rebase: state file has no stopped-sha — corrupted rebase, try --abort".println()
                return
            }

            // Index must be clean (no stage > 0 rows). The user is
            // expected to have `am-git add`ed every resolved file.
            var idx = GitIndex.read(".git")
            if (idx.hasUnmerged()) {
                "rebase: unresolved merge conflicts in the index — `am-git add` the resolved paths first".println()
                var i = 0
                while (i < idx.entries.getSize()) {
                    var e = idx.entries.get(i)
                    if (e.stage() != 0) {
                        ("  " + e.path + " (stage " + e.stage().toString() + ")").println()
                    }
                    i = i + 1
                }
                return
            }

            // Resolve the head ref. We re-read HEAD rather than
            // trusting state, so that any manual ref edits the user
            // made aren't silently clobbered.
            var head = HeadReader.read(".git")
            if (head.commitSha == null) {
                "rebase: HEAD has no commit — corrupted state, try --abort".println()
                return
            }

            var store = new ObjectStore(".git")
            // Re-fetch the stopped commit's metadata.
            if (!store.has(state.stoppedSha)) {
                ("rebase: stopped commit " + state.stoppedSha + " not in object store").println()
                return
            }
            var obj = store.read(state.stoppedSha)
            if (obj.typeCode != 1) {
                ("rebase: stopped " + state.stoppedSha + " is not a commit").println()
                return
            }
            var stoppedCommit = Commit.parse(state.stoppedSha, obj.content)

            // Build a new tree from the resolved index and commit it
            // with the stopped commit's author + message.
            var committer = Identity.loadCommitter()
            if (committer == null) {
                "rebase: identity not configured (set AM_GIT_USER_NAME and AM_GIT_USER_EMAIL)".println()
                return
            }
            var committerTime = Identity.loadCommitterDate()
            if (committerTime == null) {
                committerTime = new DateTime()
            }
            var writer = new LooseObjectWriter(".git")
            var newTreeSha = IndexTreeBuilder.build(idx, writer)
            var newCommitSha = new CommitWriter(writer).writeRawAuthor(
                newTreeSha, head.commitSha,
                stoppedCommit.author,
                committer, committerTime,
                stoppedCommit.message)

            var branch = Program.stripRefsHeads(state.headName)
            Program.moveBranchRef(branch, newCommitSha)

            ("  applied " + state.stoppedSha.substring(0UI, 7UI) + " → " +
                newCommitSha.substring(0UI, 7UI) + " '" +
                Program.firstLine(stoppedCommit.message) + "' (continued)").println()

            // Hand off to the shared loop with the rest of todo.
            state.stoppedSha = null
            Program.processRebaseTodo(state, newCommitSha, store)
        }

        // `am-git rebase --abort` — read orig-head, reset --hard to
        // it, clear the state dir.
        private static fun runRebaseAbort() {
            if (!RebaseState.isInProgress(".git")) {
                "rebase: no rebase in progress".println()
                return
            }
            var state = RebaseState.load(".git")
            if (state.origHead == null) {
                "rebase: state file missing orig-head — can't abort cleanly. Inspect .git/rebase-merge/.".println()
                return
            }
            var branch = Program.stripRefsHeads(state.headName)
            Program.moveBranchRef(branch, state.origHead)
            CheckoutClient.applyCommitToWorkTree(".git", ".", state.origHead)
            RebaseState.clear(".git")
            ("Rebase aborted; " + branch + " restored to " +
                state.origHead.substring(0UI, 7UI)).println()
        }

        // "refs/heads/<branch>" → "<branch>". The head-name file
        // stores the full ref path (real git's format); the rest of
        // am-git wants just the branch name.
        private static fun stripRefsHeads(headName: String): String? {
            var prefix = "refs/heads/"
            if (headName != null && headName.startsWith(prefix)) {
                return headName.substringToEnd(prefix.length().toUInt())
            }
            return headName
        }

        // `am-git cherry-pick <commit>` — apply one commit's
        // changes onto the current HEAD as a new commit. Reuses
        // `replayCommit` (the per-commit step of rebase) directly —
        // 3-way merge with base=<commit>'s parent, ours=HEAD,
        // theirs=<commit>. On clean apply, a new commit is made
        // with the picked commit's author + message preserved.
        //
        // Resume flow:
        //   start: `am-git cherry-pick <commit>`. On conflict,
        //          `.git/CHERRY_PICK_HEAD` is written with the
        //          picked SHA; workdir has markers, index has
        //          stages 1/2/3.
        //   user fixes files, runs `am-git add <file>...`.
        //   `am-git cherry-pick --continue` finalises the commit
        //   using the picked SHA's original author + message, then
        //   clears state.
        //   `am-git cherry-pick --abort` resets the workdir + index
        //   back to HEAD (HEAD hasn't moved since the pick started)
        //   and clears state.
        //
        // v1 limitations:
        //   * Single commit only — no `am-git cherry-pick A B C`.
        //   * Refuses merge commits (would need `-m <parent>` to
        //     pick which side to bring in).
        //   * Refuses detached HEAD (same as rebase — reuses
        //     `moveBranchRef`).
        private static fun runCherryPick(args: String[]) {
            try {
                if (args.length() < 2UI) {
                    "usage: am-git cherry-pick <commit> | --continue | --abort".println()
                    return
                }
                var first = args[1UI]
                if (first == "--continue") {
                    Program.runCherryPickContinue()
                    return
                }
                if (first == "--abort") {
                    Program.runCherryPickAbort()
                    return
                }
                if (Program.cherryPickInProgress()) {
                    "cherry-pick: a cherry-pick is already in progress. Use `--continue` or `--abort`.".println()
                    return
                }
                if (Program.revertInProgress()) {
                    "cherry-pick: revert in progress — finish or abort that first".println()
                    return
                }
                if (RebaseState.isInProgress(".git")) {
                    "cherry-pick: rebase in progress — finish or abort that first".println()
                    return
                }
                Program.runCherryPickStart(first)
            } catch (ex: Exception) {
                "cherry-pick: failed".println()
                ex.printWithStackTrace()
            }
        }

        // Initial pick. Resolves <commit>, refuses merge commits
        // (multi-parent), runs replayCommit on the current HEAD.
        // On conflict, persists `.git/CHERRY_PICK_HEAD` so
        // `--continue` knows which commit's metadata to finalise
        // with.
        private static fun runCherryPickStart(commitish: String) {
            var head = HeadReader.read(".git")
            if (head.detached) {
                "cherry-pick: cannot cherry-pick onto detached HEAD".println()
                return
            }
            if (head.commitSha == null) {
                "cherry-pick: current branch has no commits yet — cannot pick onto an unborn branch".println()
                return
            }
            var pickedSha = Program.resolveCommitish(commitish)
            if (pickedSha == null) {
                ("cherry-pick: cannot resolve '" + commitish + "'").println()
                return
            }
            var store = new ObjectStore(".git")
            if (!store.has(pickedSha)) {
                ("cherry-pick: " + pickedSha + " not in object store").println()
                return
            }
            var obj = store.read(pickedSha)
            if (obj.typeCode != 1) {
                ("cherry-pick: " + pickedSha + " is not a commit").println()
                return
            }
            var commit = Commit.parse(pickedSha, obj.content)
            if (commit.parents.getSize() > 1) {
                ("cherry-pick: " + pickedSha.substring(0UI, 7UI) +
                    " is a merge commit — v1 doesn't support `-m <parent-number>` yet.").println()
                return
            }
            if (commit.parents.getSize() == 0) {
                ("cherry-pick: " + pickedSha.substring(0UI, 7UI) +
                    " is a root commit — no parent to diff against.").println()
                return
            }

            var newSha = Program.replayCommit(commit, head.commitSha, head.branch, store)
            if (newSha == null) {
                // Conflict. Persist the picked SHA so --continue can
                // pull author + message back out of the object store.
                (pickedSha + "\n").writeToFile(".git/CHERRY_PICK_HEAD")
                ("cherry-pick: conflict applying " + pickedSha.substring(0UI, 7UI) +
                    " '" + Program.firstLine(commit.message) + "'").println()
                "  Resolve the conflicts, run `am-git add <file>...`, then `am-git cherry-pick --continue`.".println()
                "  Or `am-git cherry-pick --abort` to roll back.".println()
                return
            }

            ("Cherry-picked " + pickedSha.substring(0UI, 7UI) + " → " +
                newSha.substring(0UI, 7UI) + " '" +
                Program.firstLine(commit.message) + "'").println()
        }

        // `--continue`: index must be clean (user `add`ed the
        // resolved paths), then finalise the commit using the
        // picked SHA's original author + message.
        private static fun runCherryPickContinue() {
            if (!Program.cherryPickInProgress()) {
                "cherry-pick: no cherry-pick in progress".println()
                return
            }
            var pickedSha = Program.trim(String.readFromFile(".git/CHERRY_PICK_HEAD"))
            if (pickedSha == null || pickedSha.length() != 40) {
                "cherry-pick: .git/CHERRY_PICK_HEAD is corrupted; use --abort".println()
                return
            }

            var idx = GitIndex.read(".git")
            if (idx.hasUnmerged()) {
                "cherry-pick: unresolved merge conflicts in the index — `am-git add` the resolved paths first".println()
                var ci = 0
                while (ci < idx.entries.getSize()) {
                    var e = idx.entries.get(ci)
                    if (e.stage() != 0) {
                        ("  " + e.path + " (stage " + e.stage().toString() + ")").println()
                    }
                    ci = ci + 1
                }
                return
            }

            var head = HeadReader.read(".git")
            if (head.commitSha == null) {
                "cherry-pick: HEAD has no commit — corrupted state, use --abort".println()
                return
            }

            var store = new ObjectStore(".git")
            if (!store.has(pickedSha)) {
                ("cherry-pick: picked commit " + pickedSha + " not in object store").println()
                return
            }
            var obj = store.read(pickedSha)
            var pickedCommit = Commit.parse(pickedSha, obj.content)

            var committer = Identity.loadCommitter()
            if (committer == null) {
                "cherry-pick: identity not configured (set AM_GIT_USER_NAME and AM_GIT_USER_EMAIL)".println()
                return
            }
            var committerTime = Identity.loadCommitterDate()
            if (committerTime == null) {
                committerTime = new DateTime()
            }
            var writer = new LooseObjectWriter(".git")
            var newTreeSha = IndexTreeBuilder.build(idx, writer)
            var newCommitSha = new CommitWriter(writer).writeRawAuthor(
                newTreeSha, head.commitSha,
                pickedCommit.author,
                committer, committerTime,
                pickedCommit.message)

            Program.moveBranchRef(head.branch, newCommitSha)
            Program.deleteIfExists(".git/CHERRY_PICK_HEAD")
            ("Cherry-picked " + pickedSha.substring(0UI, 7UI) + " → " +
                newCommitSha.substring(0UI, 7UI) + " '" +
                Program.firstLine(pickedCommit.message) + "' (continued)").println()
        }

        // `--abort`: HEAD hasn't moved since the pick started (we
        // only commit after the conflict is resolved), so all we
        // need is `reset --hard HEAD` semantics: re-materialise the
        // current commit's tree and clear the index of conflict
        // stages.
        private static fun runCherryPickAbort() {
            if (!Program.cherryPickInProgress()) {
                "cherry-pick: no cherry-pick in progress".println()
                return
            }
            var head = HeadReader.read(".git")
            if (head.commitSha == null) {
                "cherry-pick: HEAD has no commit to restore to".println()
                return
            }
            CheckoutClient.applyCommitToWorkTree(".git", ".", head.commitSha)
            Program.deleteIfExists(".git/CHERRY_PICK_HEAD")
            "Cherry-pick aborted; workdir restored.".println()
        }

        // True iff `.git/CHERRY_PICK_HEAD` exists.
        private static fun cherryPickInProgress(): Bool {
            return new File(".git/CHERRY_PICK_HEAD").exists()
        }

        // `am-git revert <commit>` — produce a new commit that undoes
        // the changes introduced by <commit>. The mirror image of
        // cherry-pick: same three-way merge, but with base and theirs
        // swapped. Where cherry-pick says "given the diff from
        // commit's parent → commit, apply it onto HEAD", revert says
        // "given the diff from commit → commit's parent, apply it
        // onto HEAD" — exactly the same machinery in reverse.
        //
        // Two real differences from cherry-pick at finalisation time:
        //
        //   * **Author**: a revert commit was authored by *you*,
        //     not by the original commit's author. We call
        //     `Identity.loadAuthor` like a regular commit instead of
        //     preserving the picked commit's author line.
        //   * **Message**: defaults to
        //       Revert "<first line of original message>"
        //
        //       This reverts commit <full SHA>.
        //     — matches real git's default.
        //
        // Resume flow uses `.git/REVERT_HEAD` (real git's filename)
        // so an interrupted revert can in principle be aborted by
        // hand with real git.
        //
        // v1 limitations: single-commit only, refuses merge commits
        // (would need `-m <parent-number>`), refuses root commits
        // (no parent to diff against), refuses detached HEAD.
        private static fun runRevert(args: String[]) {
            try {
                if (args.length() < 2UI) {
                    "usage: am-git revert <commit> | --continue | --abort".println()
                    return
                }
                var first = args[1UI]
                if (first == "--continue") {
                    Program.runRevertContinue()
                    return
                }
                if (first == "--abort") {
                    Program.runRevertAbort()
                    return
                }
                if (Program.revertInProgress()) {
                    "revert: a revert is already in progress. Use `--continue` or `--abort`.".println()
                    return
                }
                if (Program.cherryPickInProgress()) {
                    "revert: cherry-pick in progress — finish or abort that first".println()
                    return
                }
                if (RebaseState.isInProgress(".git")) {
                    "revert: rebase in progress — finish or abort that first".println()
                    return
                }
                Program.runRevertStart(first)
            } catch (ex: Exception) {
                "revert: failed".println()
                ex.printWithStackTrace()
            }
        }

        // Initial revert. Same shape as cherry-pick start, but the
        // 3-way merge has base=commit's tree, theirs=parent's tree —
        // i.e. the inverse-diff direction.
        private static fun runRevertStart(commitish: String) {
            var head = HeadReader.read(".git")
            if (head.detached) {
                "revert: cannot revert onto detached HEAD".println()
                return
            }
            if (head.commitSha == null) {
                "revert: current branch has no commits — nothing to revert into".println()
                return
            }
            var pickedSha = Program.resolveCommitish(commitish)
            if (pickedSha == null) {
                ("revert: cannot resolve '" + commitish + "'").println()
                return
            }
            var store = new ObjectStore(".git")
            if (!store.has(pickedSha)) {
                ("revert: " + pickedSha + " not in object store").println()
                return
            }
            var obj = store.read(pickedSha)
            if (obj.typeCode != 1) {
                ("revert: " + pickedSha + " is not a commit").println()
                return
            }
            var commit = Commit.parse(pickedSha, obj.content)
            if (commit.parents.getSize() > 1) {
                ("revert: " + pickedSha.substring(0UI, 7UI) +
                    " is a merge commit — v1 doesn't support `-m <parent-number>` yet.").println()
                return
            }
            if (commit.parents.getSize() == 0) {
                ("revert: " + pickedSha.substring(0UI, 7UI) +
                    " is a root commit — nothing to revert (no parent to diff against).").println()
                return
            }

            var newSha = Program.invertedReplayCommit(commit, head.commitSha, head.branch, store)
            if (newSha == null) {
                (pickedSha + "\n").writeToFile(".git/REVERT_HEAD")
                ("revert: conflict reverting " + pickedSha.substring(0UI, 7UI) +
                    " '" + Program.firstLine(commit.message) + "'").println()
                "  Resolve the conflicts, run `am-git add <file>...`, then `am-git revert --continue`.".println()
                "  Or `am-git revert --abort` to roll back.".println()
                return
            }

            ("Reverted " + pickedSha.substring(0UI, 7UI) + " → " +
                newSha.substring(0UI, 7UI)).println()
        }

        // Three-way merge with base/theirs swapped relative to
        // `replayCommit`. base = the commit being reverted; theirs =
        // its parent. On clean apply, builds a new commit with the
        // current user as author and a "Revert ..." message.
        //
        // Returns the new commit SHA on success, or null on conflict.
        // On success, advances the branch ref.
        private static fun invertedReplayCommit(commit: Commit, currentHeadSha: String,
                                                  branch: String, store: ObjectStore): String? {
            var parentSha = commit.parents.get(0)
            var parentCommit = store.read(parentSha)
            // INVERTED vs replayCommit: base = commit, theirs = parent
            var baseTree = commit.treeSha
            var currentHeadCommit = store.read(currentHeadSha)
            var oursTree = WorkTree.extractRootTreeSha(currentHeadCommit.content)
            var theirsTree = WorkTree.extractRootTreeSha(parentCommit.content)

            var plan = MergePlan.compute(baseTree, oursTree, theirsTree, store)

            var idx = GitIndex.read(".git")
            var applier = new MergeApplier(".", store, idx)
            var conflicts = applier.apply(plan)
            idx.write(".git")
            if (conflicts.getSize() > 0) {
                return null
            }

            // Build a new commit. Author = the user doing the revert
            // (not the original commit's author), message =
            // `Revert "<first line>"\n\nThis reverts commit <SHA>.\n`
            var idxAfter = GitIndex.read(".git")
            var writer = new LooseObjectWriter(".git")
            var newTreeSha = IndexTreeBuilder.build(idxAfter, writer)

            var author = Identity.loadAuthor()
            var committer = Identity.loadCommitter()
            if (author == null || committer == null) {
                throw new Exception("revert: identity not configured (set AM_GIT_USER_NAME and AM_GIT_USER_EMAIL)")
            }
            var authorTime = Identity.loadAuthorDate()
            if (authorTime == null) { authorTime = new DateTime() }
            var committerTime = Identity.loadCommitterDate()
            if (committerTime == null) { committerTime = new DateTime() }

            var message = Program.buildRevertMessage(commit)
            var newCommitSha = new CommitWriter(writer).write(
                newTreeSha, currentHeadSha,
                author, authorTime,
                committer, committerTime,
                message)
            Program.moveBranchRef(branch, newCommitSha)
            return newCommitSha
        }

        // After conflict resolution + `am-git add`, finalise the
        // revert commit from the resolved index. Same shape as the
        // cherry-pick continuation, but with the revert-specific
        // author + message rules.
        private static fun runRevertContinue() {
            if (!Program.revertInProgress()) {
                "revert: no revert in progress".println()
                return
            }
            var pickedSha = Program.trim(String.readFromFile(".git/REVERT_HEAD"))
            if (pickedSha == null || pickedSha.length() != 40) {
                "revert: .git/REVERT_HEAD is corrupted; use --abort".println()
                return
            }

            var idx = GitIndex.read(".git")
            if (idx.hasUnmerged()) {
                "revert: unresolved merge conflicts in the index — `am-git add` the resolved paths first".println()
                var ri = 0
                while (ri < idx.entries.getSize()) {
                    var e = idx.entries.get(ri)
                    if (e.stage() != 0) {
                        ("  " + e.path + " (stage " + e.stage().toString() + ")").println()
                    }
                    ri = ri + 1
                }
                return
            }

            var head = HeadReader.read(".git")
            if (head.commitSha == null) {
                "revert: HEAD has no commit — corrupted state, use --abort".println()
                return
            }
            var store = new ObjectStore(".git")
            if (!store.has(pickedSha)) {
                ("revert: picked commit " + pickedSha + " not in object store").println()
                return
            }
            var obj = store.read(pickedSha)
            var pickedCommit = Commit.parse(pickedSha, obj.content)

            var author = Identity.loadAuthor()
            var committer = Identity.loadCommitter()
            if (author == null || committer == null) {
                "revert: identity not configured (set AM_GIT_USER_NAME and AM_GIT_USER_EMAIL)".println()
                return
            }
            var authorTime = Identity.loadAuthorDate()
            if (authorTime == null) { authorTime = new DateTime() }
            var committerTime = Identity.loadCommitterDate()
            if (committerTime == null) { committerTime = new DateTime() }

            var writer = new LooseObjectWriter(".git")
            var newTreeSha = IndexTreeBuilder.build(idx, writer)
            var message = Program.buildRevertMessage(pickedCommit)
            var newCommitSha = new CommitWriter(writer).write(
                newTreeSha, head.commitSha,
                author, authorTime,
                committer, committerTime,
                message)

            Program.moveBranchRef(head.branch, newCommitSha)
            Program.deleteIfExists(".git/REVERT_HEAD")
            ("Reverted " + pickedSha.substring(0UI, 7UI) + " → " +
                newCommitSha.substring(0UI, 7UI) + " (continued)").println()
        }

        // `--abort`: HEAD hasn't moved (we only commit after
        // resolution), so reset workdir + index to current HEAD.
        // Same shape as cherry-pick --abort.
        private static fun runRevertAbort() {
            if (!Program.revertInProgress()) {
                "revert: no revert in progress".println()
                return
            }
            var head = HeadReader.read(".git")
            if (head.commitSha == null) {
                "revert: HEAD has no commit to restore to".println()
                return
            }
            CheckoutClient.applyCommitToWorkTree(".git", ".", head.commitSha)
            Program.deleteIfExists(".git/REVERT_HEAD")
            "Revert aborted; workdir restored.".println()
        }

        // True iff `.git/REVERT_HEAD` exists.
        private static fun revertInProgress(): Bool {
            return new File(".git/REVERT_HEAD").exists()
        }

        // Default revert message — matches `git revert`'s template.
        //   Revert "<first line of original message>"
        //
        //   This reverts commit <full-sha>.
        private static fun buildRevertMessage(picked: Commit): String? {
            var subject = Program.firstLine(picked.message)
            return "Revert \"" + subject + "\"\n" +
                   "\n" +
                   "This reverts commit " + picked.sha + ".\n"
        }

        // FF-style "rebase" — HEAD is an ancestor of upstream, so
        // the rebased history equals upstream. Just move the ref +
        // checkout, no commits to replay.
        private static fun rebaseFastForward(head: HeadInfo, upstreamSha: String) {
            Program.moveBranchRef(head.branch, upstreamSha)
            CheckoutClient.applyCommitToWorkTree(".git", ".", upstreamSha)
            ("Fast-forward: " + head.branch + " advanced to " +
                upstreamSha.substring(0UI, 7UI)).println()
        }

        // Walk commits from `headSha` (inclusive) back to `stopSha`
        // (exclusive), enforcing linearity along the way. Returns
        // oldest-first. Returns null + prints an explanation if the
        // range contains a merge commit (v1 doesn't rebase through
        // them).
        private static fun collectLinearAhead(headSha: String, stopSha: String,
                                                store: ObjectStore): List<Commit>? {
            var chain = List<Commit>.newList<Commit>()
            var current = headSha
            loop {
                if (current == null) {
                    "rebase: walked past the merge-base without finding it (history corruption?)".println()
                    return null
                }
                if (current == stopSha) {
                    break
                }
                if (!store.has(current)) {
                    ("rebase: commit " + current + " not in object store").println()
                    return null
                }
                var obj = store.read(current)
                if (obj.typeCode != 1) {
                    ("rebase: " + current + " is not a commit").println()
                    return null
                }
                var commit = Commit.parse(current, obj.content)
                if (commit.parents.getSize() > 1) {
                    ("rebase: commit " + current.substring(0UI, 7UI) +
                        " is a merge — v1 doesn't rebase through merge commits.").println()
                    "  Either flatten the history with `git rebase --rebase-merges` (real git) or pick a different upstream.".println()
                    return null
                }
                chain.add(commit)
                if (commit.parents.getSize() == 0) {
                    "rebase: ran off the end of history (no parent) before hitting the merge-base".println()
                    return null
                }
                current = commit.parents.get(0)
            }
            // chain is newest-first; reverse for oldest-first apply order.
            return Program.reverseCommits(chain)
        }

        // Three-way merge `commit` (theirs) onto `currentHeadSha`
        // (ours) using `commit.parents.get(0)`'s tree as the base.
        // On clean apply, writes a new commit and returns its SHA;
        // on conflict, returns null. Updates the branch ref to point
        // at the new commit on success.
        //
        // Author + author-date + message are preserved verbatim from
        // the original commit; the committer line is set fresh from
        // the env (real git does the same).
        private static fun replayCommit(commit: Commit, currentHeadSha: String,
                                          branch: String, store: ObjectStore): String? {
            // Parent's tree as the merge base. The parent must exist
            // in the store — we walked through it during
            // collectLinearAhead.
            var parentSha = commit.parents.get(0)
            var parentCommit = store.read(parentSha)
            var baseTree = WorkTree.extractRootTreeSha(parentCommit.content)
            var currentHeadCommit = store.read(currentHeadSha)
            var oursTree = WorkTree.extractRootTreeSha(currentHeadCommit.content)
            var theirsTree = commit.treeSha

            var plan = MergePlan.compute(baseTree, oursTree, theirsTree, store)

            var idx = GitIndex.read(".git")
            var applier = new MergeApplier(".", store, idx)
            var conflicts = applier.apply(plan)
            idx.write(".git")

            if (conflicts.getSize() > 0) {
                return null
            }

            // Build a new tree from the resolved index, then commit.
            var idxAfter = GitIndex.read(".git")
            var writer = new LooseObjectWriter(".git")
            var newTreeSha = IndexTreeBuilder.build(idxAfter, writer)

            var committer = Identity.loadCommitter()
            if (committer == null) {
                throw new Exception("rebase: identity not configured (set AM_GIT_USER_NAME and AM_GIT_USER_EMAIL)")
            }
            var committerTime = Identity.loadCommitterDate()
            if (committerTime == null) {
                committerTime = new DateTime()
            }

            var newCommitSha = new CommitWriter(writer).writeRawAuthor(
                newTreeSha, currentHeadSha,
                commit.author,           // preserve original author line verbatim
                committer, committerTime,
                commit.message)

            // Move the branch ref forward to the new commit.
            Program.moveBranchRef(branch, newCommitSha)
            return newCommitSha
        }

        // Reverse a List<Commit>. AmLang's List doesn't have a
        // built-in reverse, so we walk it bottom-up.
        private static fun reverseCommits(in: List<Commit>): List<Commit> {
            var out = List<Commit>.newList<Commit>()
            var i = in.getSize() - 1
            while (i >= 0) {
                out.add(in.get(i))
                i = i - 1
            }
            return out
        }

        // First line of a multi-line commit message (everything up
        // to the first `\n`). Used for one-line progress output.
        private static fun firstLine(message: String): String {
            if (message == null) {
                return ""
            }
            var nl = message.indexOf("\n")
            if (nl < 0) {
                return message
            }
            return message.substring(0UI, nl.toUInt())
        }

        // Centralised "write a SHA to refs/heads/<branch>" — used
        // by both rebase and reset, kept here so the
        // ensureParentDir + trailing-newline contract lives in one
        // spot.
        private static fun moveBranchRef(branch: String, sha: String) {
            var refPath = ".git/refs/heads/" + branch
            Repository.ensureParentDir(refPath)
            (sha + "\n").writeToFile(refPath)
        }

        // `am-git reset [--soft|--mixed|--hard] [<commit>]`
        //
        //   --soft           move HEAD only. Index + working tree
        //                    untouched (your staged changes stay
        //                    staged; uncommitted edits stay).
        //   --mixed (default)  move HEAD AND reset the index to
        //                    <commit>'s tree. Working tree untouched.
        //   --hard           move HEAD, reset index, AND overwrite
        //                    the working tree with <commit>'s tree.
        //                    Destroys uncommitted edits — same
        //                    semantics as real git.
        //
        // <commit> defaults to HEAD if omitted — i.e. `am-git reset`
        // unstages everything (mixed) without changing where HEAD
        // points.
        //
        // Detached HEAD: writes the new SHA directly to `.git/HEAD`.
        // Otherwise updates `.git/refs/heads/<branch>`.
        private static fun runReset(args: String[]) {
            try {
                var mode = "mixed"
                var target: String? = null
                var i = 1UI
                while (i < args.length()) {
                    var a = args[i]
                    if (a == "--soft") {
                        mode = "soft"
                    } else if (a == "--mixed") {
                        mode = "mixed"
                    } else if (a == "--hard") {
                        mode = "hard"
                    } else if (a.startsWith("--")) {
                        ("reset: unrecognised flag '" + a + "'").println()
                        return
                    } else {
                        if (target != null) {
                            "usage: am-git reset [--soft|--mixed|--hard] [<commit>]".println()
                            return
                        }
                        target = a
                    }
                    i = i + 1UI
                }

                var head = HeadReader.read(".git")
                if (head.commitSha == null) {
                    "reset: current branch has no commits — nothing to reset".println()
                    return
                }
                if (target == null) {
                    target = head.commitSha
                }
                var targetSha = Program.resolveCommitish(target)
                if (targetSha == null) {
                    ("reset: cannot resolve '" + target + "'").println()
                    return
                }
                var store = new ObjectStore(".git")
                if (!store.has(targetSha)) {
                    ("reset: " + targetSha + " is not in the object store").println()
                    return
                }
                var obj = store.read(targetSha)
                if (obj.typeCode != 1) {
                    ("reset: " + target + " is not a commit").println()
                    return
                }

                // Move the ref / detached HEAD first. The applier
                // below reads HEAD's tree, but we want the ref to
                // already point at the new commit so a subsequent
                // status / log reflects the move even if the working-
                // tree write fails partway through.
                if (head.detached) {
                    (targetSha + "\n").writeToFile(".git/HEAD")
                } else {
                    var refPath = ".git/refs/heads/" + head.branch
                    Repository.ensureParentDir(refPath)
                    (targetSha + "\n").writeToFile(refPath)
                }

                if (mode == "soft") {
                    Program.printResetSummary(head, targetSha, "soft")
                    return
                }

                // --mixed and --hard both need the index re-seeded
                // from <target>'s tree. --hard additionally
                // materialises the tree into the working tree.
                if (mode == "hard") {
                    CheckoutClient.applyCommitToWorkTree(".git", ".", targetSha)
                } else {
                    // mixed: index only.
                    var rootTreeSha = WorkTree.extractRootTreeSha(obj.content)
                    GitIndex.fromTree(rootTreeSha, store).write(".git")
                }

                // Clear any in-progress merge state — a reset is the
                // canonical way to abandon one (matches `git merge
                // --abort` semantics when the target is HEAD).
                Program.deleteIfExists(".git/MERGE_HEAD")
                Program.deleteIfExists(".git/MERGE_MSG")

                Program.printResetSummary(head, targetSha, mode)
            } catch (ex: Exception) {
                "reset: failed".println()
                ex.printWithStackTrace()
            }
        }

        private static fun printResetSummary(prevHead: HeadInfo, targetSha: String, mode: String) {
            var prevShort = "(unborn)"
            if (prevHead.commitSha != null) {
                prevShort = prevHead.commitSha.substring(0UI, 7UI)
            }
            var newShort = targetSha.substring(0UI, 7UI)
            var label = "HEAD"
            if (!prevHead.detached) {
                label = prevHead.branch
            }
            ("Reset (" + mode + ") " + label + " from " + prevShort +
                " to " + newShort).println()
        }

        // `am-git diff [--staged|--cached] [--name-only|--name-status] [<commit> [<commit>]]`
        //
        // Path-level only — we don't have an LCS line-differ yet.
        // With `--name-only` we emit one path per line. With
        // `--name-status` (and the no-flag default) we emit
        // `<A|M|D>\t<path>`.
        //
        // Snapshot pairs:
        //
        //   am-git diff                  worktree vs index
        //   am-git diff --staged         index vs HEAD
        //   am-git diff HEAD             worktree vs HEAD
        //   am-git diff <commit>         worktree vs <commit>
        //   am-git diff <a> <b>          tree-of-<a> vs tree-of-<b>
        //
        // `--cached` is accepted as an alias for `--staged` (real
        // git accepts both).
        private static fun runDiff(args: String[]) {
            try {
                var nameOnly = false
                var nameStatus = false
                var staged = false
                var positional = List<String>.newList<String>()
                var i = 1UI
                while (i < args.length()) {
                    var a = args[i]
                    if (a == "--name-only") {
                        nameOnly = true
                    } else if (a == "--name-status") {
                        nameStatus = true
                    } else if (a == "--staged" || a == "--cached") {
                        staged = true
                    } else if (a.startsWith("--")) {
                        ("diff: unrecognised flag '" + a + "'").println()
                        return
                    } else {
                        positional.add(a)
                    }
                    i = i + 1UI
                }
                if (positional.getSize() > 2) {
                    "usage: am-git diff [--staged|--cached] [--name-only|--name-status] [<commit> [<commit>]]".println()
                    return
                }

                var store = new ObjectStore(".git")
                var left = new HashMap<String, String>()
                var right = new HashMap<String, String>()

                if (staged) {
                    // index vs HEAD: left = HEAD's tree, right = index.
                    var head = HeadReader.read(".git")
                    left = DiffCommand.snapshotCommit(head.commitSha, store)
                    right = DiffCommand.snapshotIndex(".git")
                    if (positional.getSize() > 0) {
                        "diff: --staged ignores any positional commit args".println()
                    }
                } else if (positional.getSize() == 2) {
                    // tree-of-<a> vs tree-of-<b>
                    var aSha = Program.resolveCommitish(positional.get(0))
                    var bSha = Program.resolveCommitish(positional.get(1))
                    if (aSha == null) {
                        ("diff: cannot resolve '" + positional.get(0) + "'").println()
                        return
                    }
                    if (bSha == null) {
                        ("diff: cannot resolve '" + positional.get(1) + "'").println()
                        return
                    }
                    left = DiffCommand.snapshotCommit(aSha, store)
                    right = DiffCommand.snapshotCommit(bSha, store)
                } else if (positional.getSize() == 1) {
                    // worktree vs <commit>: left = <commit>, right = worktree
                    var cSha = Program.resolveCommitish(positional.get(0))
                    if (cSha == null) {
                        ("diff: cannot resolve '" + positional.get(0) + "'").println()
                        return
                    }
                    left = DiffCommand.snapshotCommit(cSha, store)
                    right = DiffCommand.snapshotWorkTree(".", ".git")
                } else {
                    // No args: worktree vs index.
                    left = DiffCommand.snapshotIndex(".git")
                    right = DiffCommand.snapshotWorkTree(".", ".git")
                }

                var entries = DiffCommand.compute(left, right)
                if (entries.getSize() == 0) {
                    return
                }
                if (!nameOnly && !nameStatus) {
                    // Default: name-status, with a one-line note that
                    // hunk-level diff isn't wired up yet. The note
                    // goes first so script use of `am-git diff
                    // --name-status` (which suppresses it) stays
                    // clean.
                    "# am-git diff currently only emits path-level changes — use --name-only or --name-status to suppress this note.".println()
                    nameStatus = true
                }
                var text = DiffCommand.render(entries, nameOnly)
                Program.printNoNewline(text)
            } catch (ex: Exception) {
                "diff: failed".println()
                ex.printWithStackTrace()
            }
        }

        // print() always appends a newline; DiffCommand.render already
        // terminates each line with \n, so we want to write the
        // string as-is. Use stdout's binary-stream-ish path: build a
        // String + println on a trimmed copy.
        private static fun printNoNewline(s: String) {
            // The output already ends in \n per render; trim one off
            // and use println to avoid a doubled newline.
            if (s.endsWith("\n")) {
                s.substring(0UI, (s.length() - 1).toUInt()).println()
            } else {
                s.println()
            }
        }

        // `am-git show [<commit>]` — print a commit's metadata
        // (SHA, parents, author, committer, message) plus a
        // path-level name-status of what it changed. With no
        // arg, defaults to HEAD.
        //
        // Once we have a real hunk-level diff library, this becomes
        // the obvious place to emit full unified diffs per file.
        // Until then, name-status is enough to answer "what did
        // this commit touch?" from the command line.
        private static fun runShow(args: String[]) {
            try {
                if (args.length() > 2UI) {
                    "usage: am-git show [<commit>]".println()
                    return
                }
                var commitish = "HEAD"
                if (args.length() == 2UI) {
                    commitish = args[1UI]
                }
                var sha = Program.resolveCommitish(commitish)
                if (sha == null) {
                    ("show: cannot resolve '" + commitish + "'").println()
                    return
                }
                var store = new ObjectStore(".git")
                if (!store.has(sha)) {
                    ("show: " + sha + " not in object store").println()
                    return
                }
                var obj = store.read(sha)
                if (obj.typeCode != 1) {
                    ("show: " + sha + " is not a commit").println()
                    return
                }
                var commit = Commit.parse(sha, obj.content)

                // Header — same shape as `git show`'s default text.
                ("commit " + commit.sha).println()
                var pi = 0
                while (pi < commit.parents.getSize()) {
                    ("parent " + commit.parents.get(pi)).println()
                    pi = pi + 1
                }
                ("Author: " + commit.author).println()
                ("Commit: " + commit.committer).println()
                "".println()

                // Message — indent every line by 4 spaces, matching
                // real git. We don't try to detect "merge"-style
                // boilerplate or trailers, just print as-is.
                var msg = commit.message
                if (msg == null) {
                    msg = ""
                }
                var msgLines = msg.split(10US)
                var mi = 0
                while (mi < msgLines.length().toInt()) {
                    var line = msgLines[mi.toUInt()]
                    if (line.length() == 0 && mi == msgLines.length().toInt() - 1) {
                        // Skip the synthetic trailing empty line that
                        // split() produces when the message ends with
                        // `\n` — otherwise we'd emit an extra blank
                        // line at the end.
                        mi = mi + 1
                        continue
                    }
                    ("    " + line).println()
                    mi = mi + 1
                }
                "".println()

                // Path-level diff: parent tree → this commit's tree.
                // For root commits (no parent), the implicit "base"
                // is the empty tree, so every file shows up as Added.
                var thisTree = commit.treeSha
                var parentTree: String? = null
                if (commit.parents.getSize() > 0) {
                    var p0 = store.read(commit.parents.get(0))
                    parentTree = WorkTree.extractRootTreeSha(p0.content)
                }
                var left = new HashMap<String, String>()
                var right = new HashMap<String, String>()
                if (parentTree != null) {
                    StatusReport.collectTreePaths(parentTree, "", left, store)
                }
                StatusReport.collectTreePaths(thisTree, "", right, store)

                var entries = DiffCommand.compute(left, right)
                if (entries.getSize() == 0) {
                    "(no files changed)".println()
                    return
                }
                var text = DiffCommand.render(entries, false)
                Program.printNoNewline(text)
            } catch (ex: Exception) {
                ("show: " + ex.message).println()
            }
        }

        // `am-git ls-stages` — print every index entry as
        // `<mode> <sha> <stage>\t<path>`, mirroring
        // `git ls-files --stage`. Useful when debugging conflict
        // resolution: stage 0 = resolved, 1/2/3 = base/ours/theirs.
        //
        // With `--rewrite` it also writes the index back out unchanged
        // — a round-trip sanity check that proves stage bits and the
        // rest of the entry record survive a read/write cycle byte-
        // for-byte (modulo extension blocks we don't emit).
        private static fun runLsStages(args: String[]) {
            try {
                var rewrite = false
                var i = 1UI
                while (i < args.length()) {
                    if (args[i] == "--rewrite") {
                        rewrite = true
                    }
                    i++
                }
                var idx = GitIndex.read(".git")
                var j = 0
                while (j < idx.entries.getSize()) {
                    var e = idx.entries.get(j)
                    var modeStr = Program.modeOctal(e.mode)
                    (modeStr + " " + e.sha + " " + e.stage().toString() + "\t" + e.path).println()
                    j = j + 1
                }
                if (rewrite) {
                    idx.write(".git")
                    "(index rewritten)".println()
                }
            } catch (ex: Exception) {
                ("ls-stages: " + ex.message).println()
            }
        }

        // Mode bits → 6-char octal string (matches `git ls-files --stage`).
        private static fun modeOctal(mode: UInt): String? {
            // 33188 = 0o100644, 33261 = 0o100755, 40960 = 0o120000,
            // 57344 = 0o160000, 16384 = 0o040000 (tree).
            if (mode == 33261UI) { return "100755" }
            if (mode == 40960UI) { return "120000" }
            if (mode == 57344UI) { return "160000" }
            if (mode == 16384UI) { return "040000" }
            return "100644"
        }

        // Resolve a "commit-ish" — a 40-char hex SHA passes through,
        // anything else is treated as a local branch name and looked
        // up under .git/refs/heads/. Returns null if neither path
        // works.
        private static fun resolveCommitish(s: String): String? {
            if (s == null || s.length() == 0) {
                return null
            }
            if (s.length() == 40 && Program.isHex(s)) {
                return s
            }
            // Special: the literal `HEAD` resolves to whatever the
            // current HEAD points at — `HeadReader` already handles
            // detached / symbolic / unborn cases.
            if (s == "HEAD") {
                var head = HeadReader.read(".git")
                return head.commitSha
            }
            // Try local branches first, then tags. Matches real git's
            // "loose-ref" search order (heads/, tags/, remotes/), at
            // least for the two ref classes we support today.
            // (Annotated tags would point at a tag object; we only
            // write lightweight tags, so the file contents are
            // already a commit SHA. If somebody created an annotated
            // tag with real git in the same repo, downstream commands
            // would see the tag-object SHA — not a commit — and
            // refuse. Worth peeling through tag objects when we ship
            // annotated tags.)
            var branchPath = ".git/refs/heads/" + s
            if (new File(branchPath).exists()) {
                return Program.trim(String.readFromFile(branchPath))
            }
            var tagPath = ".git/refs/tags/" + s
            if (new File(tagPath).exists()) {
                return Program.trim(String.readFromFile(tagPath))
            }
            return null
        }

        private static fun isHex(s: String): Bool {
            var i: UInt = 0UI
            while (i < s.length()) {
                var c = s.characterAt(i).toInt()
                var ok = (c >= 48 && c <= 57) ||      // 0-9
                         (c >= 97 && c <= 102) ||     // a-f
                         (c >= 65 && c <= 70)         // A-F
                if (!ok) {
                    return false
                }
                i++
            }
            return true
        }

        // Strip trailing CR/LF/whitespace — ref files have a trailing
        // newline.
        private static fun trim(raw: String): String {
            var end = raw.length()
            var go = true
            while (go) {
                if (end <= 0) {
                    go = false
                } else {
                    var c = raw.characterAt((end - 1).toUInt()).toInt()
                    if (c == 10 || c == 13 || c == 32 || c == 9) {
                        end = end - 1
                    } else {
                        go = false
                    }
                }
            }
            return raw.substring(0UI, end.toUInt())
        }

        // Stage one or more paths into `.git/index`. Mirrors
        // `git add <path>...` — accepts files and directories; `.`
        // means "everything except .git/".
        private static fun runAdd(args: String[]) {
            try {
                if (args.length() < 2UI) {
                    "usage: am-git add <path>...".println()
                    return
                }
                var paths = List<String>.newList<String>()
                var i = 1
                while (i < args.length().toInt()) {
                    paths.add(args[i.toUInt()])
                    i = i + 1
                }
                var n = AddCommand.run(".git", ".", paths)
                ("Staged " + n.toString() + " file(s)").println()
            } catch (ex: Exception) {
                "add: failed".println()
                ex.printWithStackTrace()
            }
        }

        // Remove an entry from the index. `--cached` (default for
        // anything we recognise here) leaves the working-tree file
        // alone; the absence of the flag also deletes it from disk.
        private static fun runRm(args: String[]) {
            try {
                if (args.length() < 2UI) {
                    "usage: am-git rm [--cached] <path>...".println()
                    return
                }
                var cached = false
                var firstPath = 1
                if (args[1UI] == "--cached") {
                    cached = true
                    firstPath = 2
                }
                if (args.length().toInt() <= firstPath) {
                    "usage: am-git rm [--cached] <path>...".println()
                    return
                }
                var idx = GitIndex.read(".git")
                var removed = 0
                var i = firstPath
                while (i < args.length().toInt()) {
                    var p = args[i.toUInt()]
                    if (p.startsWith("./")) {
                        p = p.substringToEnd(2UI)
                    }
                    if (idx.removeByPath(p)) {
                        removed = removed + 1
                        if (!cached) {
                            var f = new File(p)
                            if (f.exists()) {
                                File.delete(p)
                            }
                        }
                    } else {
                        ("rm: '" + p + "' not in index").println()
                    }
                    i = i + 1
                }
                idx.write(".git")
                ("Removed " + removed.toString() + " entry/entries from the index").println()
            } catch (ex: Exception) {
                ("rm: " + ex.message).println()
            }
        }

        // `am-git mv <src> <dst>` — rename a tracked file on disk and
        // in the index. Same blob SHA is preserved (we're not
        // re-hashing); the index entry's path changes.
        //
        // Path semantics:
        //   * If <dst> ends with `/`, it's treated as a target
        //     directory and <src>'s basename is appended.
        //   * Both <src> and <dst> are interpreted relative to the
        //     work tree root.
        //
        // v1 limitations:
        //   * Single source only — `git mv a b c target/` (multi-source
        //     into a dir) isn't supported.
        //   * Files only — directory renames need recursion.
        //   * No `-f` (force overwrite). Refuses if <dst> already
        //     exists in the workdir or is tracked in the index.
        //   * <src> must be tracked. Renaming an untracked file
        //     should use plain `mv` from the shell.
        private static fun runMv(args: String[]) {
            try {
                if (args.length() != 3UI) {
                    "usage: am-git mv <source> <destination>".println()
                    return
                }
                var src = Program.normaliseRel(args[1UI])
                var dst = args[2UI]
                if (dst.endsWith("/")) {
                    // Target is a directory — append source basename.
                    dst = dst + Program.basename(src)
                }
                dst = Program.normaliseRel(dst)
                if (src == dst) {
                    ("mv: source and destination are the same: " + src).println()
                    return
                }

                var srcFile = new File(src)
                if (!srcFile.exists()) {
                    ("mv: source '" + src + "' does not exist").println()
                    return
                }
                if (srcFile.isDirectory()) {
                    "mv: directory renames not supported yet (v1: single files only)".println()
                    return
                }

                var idx = GitIndex.read(".git")
                var srcEntry = idx.findByPath(src)
                if (srcEntry == null) {
                    ("mv: '" + src + "' is not tracked").println()
                    return
                }

                // Don't clobber an existing destination — real git
                // requires `-f` for that, we don't support it yet.
                var dstFile = new File(dst)
                if (dstFile.exists()) {
                    ("mv: destination '" + dst + "' already exists").println()
                    return
                }
                if (idx.findByPath(dst) != null) {
                    ("mv: destination '" + dst + "' is already tracked in the index").println()
                    return
                }

                // Move on disk first — if rename fails, leave the
                // index alone so we don't end up with an inconsistent
                // state.
                Repository.ensureParentDir(dst)
                if (!srcFile.move(dst)) {
                    ("mv: failed to move '" + src + "' to '" + dst + "'").println()
                    return
                }

                // Index update: drop old entry, insert new one with
                // the same blob SHA / mode but the new path.
                idx.removeByPath(src)
                var moved = new IndexEntry(
                    dst, srcEntry.sha, srcEntry.mode, srcEntry.size,
                    srcEntry.mtimeSeconds, srcEntry.mtimeNanos,
                    srcEntry.ctimeSeconds, srcEntry.ctimeNanos,
                    srcEntry.dev, srcEntry.ino,
                    srcEntry.uid, srcEntry.gid,
                    0US)  // flags reset — namelen is set on write
                idx.upsert(moved)
                idx.write(".git")
                ("Renamed " + src + " → " + dst).println()
            } catch (ex: Exception) {
                ("mv: " + ex.message).println()
            }
        }

        // Strip a leading "./" and a single trailing "/" from a
        // user-supplied path so the rest of am-git compares paths
        // consistently (HEAD trees, index entries, status lines all
        // omit those).
        private static fun normaliseRel(p: String): String {
            var s = p
            if (s.startsWith("./")) {
                s = s.substringToEnd(2UI)
            }
            while (s.length() > 1 && s.endsWith("/")) {
                s = s.substring(0UI, (s.length() - 1).toUInt())
            }
            return s
        }

        // Basename — everything after the last `/`. Returns the
        // whole string if there's no slash.
        private static fun basename(p: String): String {
            var slash = p.lastIndexOf("/")
            if (slash < 0) {
                return p
            }
            return p.substringToEnd((slash + 1).toUInt())
        }

        // Compare the working tree to HEAD's tree and print changed
        // paths in `git status --short` style.
        // `am-git status [--porcelain]`
        //
        // Without --porcelain: human-friendly output with the
        //   "On branch …" header and a "nothing to commit, working
        //   tree clean" line when there are no changes.
        // With --porcelain: stable machine-readable output — branch
        //   header suppressed, clean tree emits nothing at all, and
        //   each entry stays in the `XY <path>` form (already the
        //   porcelain v1 shape `StatusReport.printGroup` produces).
        //
        // Flag matching is exact ("--porcelain"); we don't yet
        // accept `--porcelain=v1` / `--porcelain=v2` variants.
        private static fun runStatus(args: String[]) {
            try {
                var porcelain = false
                var i = 1
                while (i < args.length().toInt()) {
                    var a = args[i.toUInt()]
                    if (a == "--porcelain") {
                        porcelain = true
                    } else {
                        ("status: unknown option '" + a + "'").println()
                        return
                    }
                    i = i + 1
                }
                StatusReport.run(".git", ".", porcelain)
            } catch (ex: Exception) {
                ("status: " + ex.message).println()
            }
        }

        // `am-git checkout <branch>` — repoint HEAD at refs/heads/<branch>
        // and bring the working tree in line with that branch's tip.
        // Refuses if the branch doesn't exist locally; doesn't detect
        // dirty files (clobbers them).
        private static fun runCheckout(args: String[]) {
            try {
                if (args.length() != 2UI) {
                    "usage: am-git checkout <branch>".println()
                    return
                }
                CheckoutClient.checkout(".git", ".", args[1UI])
            } catch (ex: Exception) {
                ("checkout: " + ex.message).println()
            }
        }

        // `am-git branch`              — list local branches with a
        //                                 `*` next to the current one.
        // `am-git branch <name>`       — create a new branch at HEAD.
        // `am-git branch -d <name>`    — delete a branch (refuses to
        //                                 delete the current one).
        private static fun runBranch(args: String[]) {
            try {
                if (args.length() == 1UI) {
                    Program.listBranches()
                    return
                }
                if (args.length() == 3UI && args[1UI] == "-d") {
                    Program.deleteBranch(args[2UI])
                    return
                }
                if (args.length() == 2UI) {
                    Program.createBranch(args[1UI])
                    return
                }
                "usage: am-git branch [<name> | -d <name>]".println()
            } catch (ex: Exception) {
                ("branch: " + ex.message).println()
            }
        }

        private static fun listBranches() {
            var head = HeadReader.read(".git")
            var currentBranch: String? = null
            if (!head.detached) {
                currentBranch = head.branch
            }
            var names = Program.collectBranchNames(".git/refs/heads", "")
            Program.sortStringsBytewise(names)
            var k = 0
            while (k < names.getSize()) {
                var n = names.get(k)
                var marker = "  "
                if (n == currentBranch) {
                    marker = "* "
                }
                (marker + n).println()
                k = k + 1
            }
        }

        // Recurse into refs/heads — branch names can contain slashes
        // (`feature/foo`) which become nested directories on disk.
        private static fun collectBranchNames(dir: String, prefix: String): List<String> {
            var out = List<String>.newList<String>()
            var d = new File(dir)
            if (!d.exists()) {
                return out
            }
            var entries = d.listFiles()
            var i = 0
            while (i < entries.length().toInt()) {
                var f = entries[i.toUInt()]
                var name = f.getName()
                if (f.isDirectory()) {
                    var nested = Program.collectBranchNames(f.toString(), prefix + name + "/")
                    var n = 0
                    while (n < nested.getSize()) {
                        out.add(nested.get(n))
                        n = n + 1
                    }
                } else {
                    out.add(prefix + name)
                }
                i = i + 1
            }
            return out
        }

        private static fun createBranch(name: String) {
            var head = HeadReader.read(".git")
            if (head.commitSha == null) {
                "branch: HEAD has no commit yet — create one first".println()
                return
            }
            var path = ".git/refs/heads/" + name
            var existing = new File(path)
            if (existing.exists()) {
                ("branch: refs/heads/" + name + " already exists").println()
                return
            }
            Repository.ensureParentDir(path)
            (head.commitSha + "\n").writeToFile(path)
            ("Created refs/heads/" + name + " at " + head.commitSha).println()
        }

        private static fun deleteBranch(name: String) {
            var head = HeadReader.read(".git")
            if (!head.detached && head.branch == name) {
                ("branch: refusing to delete current branch '" + name + "'").println()
                return
            }
            var path = ".git/refs/heads/" + name
            var f = new File(path)
            if (!f.exists()) {
                ("branch: refs/heads/" + name + " does not exist").println()
                return
            }
            File.delete(path)
            ("Deleted refs/heads/" + name).println()
        }

        // `am-git tag`                     — list every tag, sorted.
        // `am-git tag <name>`              — lightweight tag at HEAD.
        // `am-git tag <name> <commit>`     — lightweight tag at <commit>.
        //                                    <commit> goes through
        //                                    `resolveCommitish`, so
        //                                    branch names + SHAs +
        //                                    `HEAD` all work.
        // `am-git tag -d <name>`           — delete a tag.
        //
        // v1 limitations:
        //   * Lightweight tags only — the ref file contains the commit
        //     SHA directly. Annotated tags (a separate tag object with
        //     its own author/date/message) aren't written yet.
        //   * No `-f` to overwrite an existing tag (real git's safety
        //     default). Delete and recreate to move a tag.
        private static fun runTag(args: String[]) {
            try {
                if (args.length() == 1UI) {
                    Program.listTags()
                    return
                }
                if (args.length() == 3UI && args[1UI] == "-d") {
                    Program.deleteTag(args[2UI])
                    return
                }
                if (args.length() == 2UI) {
                    Program.createTag(args[1UI], null)
                    return
                }
                if (args.length() == 3UI) {
                    Program.createTag(args[1UI], args[2UI])
                    return
                }
                "usage: am-git tag [<name> [<commit>]] | tag -d <name>".println()
            } catch (ex: Exception) {
                ("tag: " + ex.message).println()
            }
        }

        // List tags, one per line, sorted alphabetically. No marker
        // for "current" — tags don't have a "checked out" concept
        // the way branches do.
        private static fun listTags() {
            // collectBranchNames is name-misleading but
            // implementation-neutral — it just walks any refs/* dir.
            var names = Program.collectBranchNames(".git/refs/tags", "")
            Program.sortStringsBytewise(names)
            var k = 0
            while (k < names.getSize()) {
                names.get(k).println()
                k = k + 1
            }
        }

        // Bytewise lexicographic sort. AmLang's String `<` doesn't
        // compare contents, so listBranches / listTags both have to
        // walk the code units themselves — same workaround
        // GitIndex.compareBytewise uses for its on-disk index sort.
        private static fun sortStringsBytewise(list: List<String>) {
            var n = list.getSize()
            var i = 0
            while (i < n - 1) {
                var j = i + 1
                while (j < n) {
                    if (Program.compareBytewise(list.get(j), list.get(i)) < 0) {
                        var tmp = list.get(i)
                        list.set(i, list.get(j))
                        list.set(j, tmp)
                    }
                    j = j + 1
                }
                i = i + 1
            }
        }

        private static fun compareBytewise(a: String, b: String): Int {
            var la = a.length()
            var lb = b.length()
            var min = la
            if (lb < min) {
                min = lb
            }
            var i: UInt = 0UI
            while (i.toInt() < min) {
                var ca = a.characterAt(i).toInt()
                var cb = b.characterAt(i).toInt()
                if (ca != cb) {
                    return ca - cb
                }
                i++
            }
            return la - lb
        }

        // Create a lightweight tag at the resolved commit. Refuses
        // to overwrite an existing tag (matches real git's default).
        // Also refuses if the target SHA isn't actually in the
        // object store — `resolveCommitish` treats any 40-char hex
        // as a valid SHA without checking existence, so without
        // this guard `am-git tag x ffff...` would happily create a
        // dangling ref.
        private static fun createTag(name: String, commitish: String?) {
            var targetSha: String? = null
            if (commitish == null) {
                var head = HeadReader.read(".git")
                if (head.commitSha == null) {
                    "tag: HEAD has no commit yet — create one first".println()
                    return
                }
                targetSha = head.commitSha
            } else {
                targetSha = Program.resolveCommitish(commitish)
                if (targetSha == null) {
                    ("tag: cannot resolve '" + commitish + "'").println()
                    return
                }
                var store = new ObjectStore(".git")
                if (!store.has(targetSha)) {
                    ("tag: " + targetSha + " is not in the object store").println()
                    return
                }
            }
            var path = ".git/refs/tags/" + name
            var existing = new File(path)
            if (existing.exists()) {
                ("tag: refs/tags/" + name + " already exists").println()
                return
            }
            Repository.ensureParentDir(path)
            (targetSha + "\n").writeToFile(path)
            ("Created refs/tags/" + name + " at " + targetSha).println()
        }

        private static fun deleteTag(name: String) {
            var path = ".git/refs/tags/" + name
            var f = new File(path)
            if (!f.exists()) {
                ("tag: refs/tags/" + name + " does not exist").println()
                return
            }
            File.delete(path)
            ("Deleted refs/tags/" + name).println()
        }

        // Walk commit ancestry from HEAD, printing each commit's sha,
        // author, and message. Follows the first parent only — same
        // behaviour as `git log --first-parent` — which keeps merges
        // from exploding the output. `-n N` caps the count.
        private static fun runLog(args: String[]) {
            try {
                var limit = -1
                var i = 1
                while (i < args.length().toInt()) {
                    var a = args[i.toUInt()]
                    if (a == "-n" && i + 1 < args.length().toInt()) {
                        limit = Int.parse(args[(i + 1).toUInt()])
                        i = i + 2
                    } else {
                        ("log: unrecognised arg '" + a + "'").println()
                        return
                    }
                }

                var head = HeadReader.read(".git")
                if (head.commitSha == null) {
                    "log: no commits yet".println()
                    return
                }
                var store = new ObjectStore(".git")
                var current = head.commitSha
                var shown = 0
                loop {
                    if (current == null) {
                        break
                    }
                    if (limit >= 0 && shown >= limit) {
                        break
                    }
                    if (!store.has(current)) {
                        ("log: missing object " + current).println()
                        break
                    }
                    var obj = store.read(current)
                    if (obj.typeCode != 1) {
                        ("log: " + current + " is not a commit").println()
                        break
                    }
                    var c = Commit.parse(current, obj.content)
                    ("commit " + c.sha).println()
                    if (c.author != null) {
                        ("Author: " + c.author).println()
                    }
                    "".println()
                    // Indent the message body four spaces, like git's
                    // default `medium` format.
                    var lines = c.message.split(10US)
                    var li = 0
                    while (li < lines.length().toInt()) {
                        var line = lines[li.toUInt()]
                        if (li == lines.length().toInt() - 1 && line.length() == 0) {
                            break
                        }
                        ("    " + line).println()
                        li = li + 1
                    }
                    "".println()
                    shown = shown + 1
                    if (c.parents.getSize() == 0) {
                        break
                    }
                    current = c.parents.get(0)
                }
            } catch (ex: Exception) {
                ("log: " + ex.message).println()
            }
        }

        // Pull new objects + refs from the remote into our `.git`
        // directory. Updates `refs/remotes/<remote>/<branch>` and
        // `refs/tags/*`; doesn't touch the working tree or local
        // branches.
        //
        //   am-git fetch                     (URL + name from .git/config)
        //   am-git fetch <remote-name>       (URL from config, override name)
        //   am-git fetch <remote-url> [<remote-name>]
        //
        // <remote-name> defaults to "origin" — it's the prefix used
        // for the remote-tracking refs on disk.
        private static fun runFetch(args: String[]) {
            try {
                var remoteUrl: String? = null
                var remoteName = "origin"
                if (args.length() >= 2UI) {
                    var arg = args[1UI]
                    if (Program.looksLikeUrl(arg)) {
                        remoteUrl = arg
                        if (args.length() >= 3UI) {
                            remoteName = args[2UI]
                        }
                    } else {
                        remoteName = arg
                    }
                }
                if (remoteUrl == null) {
                    remoteUrl = Program.urlFromConfig(remoteName)
                    if (remoteUrl == null) {
                        ("fetch: no URL passed and remote '" + remoteName + "' not in .git/config").println()
                        return
                    }
                }
                FetchClient.fetch(".git", remoteUrl, remoteName)
            } catch (ex: Exception) {
                ("fetch: " + ex.message).println()
            }
        }

        // Heuristic — pull's first arg might be a URL or a remote
        // name. A URL contains "://"; a remote name doesn't.
        private static fun looksLikeUrl(s: String): Bool {
            return s.indexOf("://") > 0
        }

        private static fun urlFromConfig(remoteName: String): String {
            var cfg = GitConfig.read(".git")
            return cfg.getRemoteUrl(remoteName)
        }

        // Push the current branch (or an explicitly named one) to the
        // remote. Usage:
        //
        //   am-git push                              (URL from .git/config, branch from HEAD)
        //   am-git push <branch>                     (URL from config, named branch)
        //   am-git push <remote-url> [<branch>]
        //
        // Credentials come from AM_GIT_USERNAME / AM_GIT_PASSWORD; for
        // GitHub these are the login + a personal-access-token.
        private static fun runPush(args: String[]) {
            try {
                var remoteUrl: String? = null
                var branch: String? = null
                if (args.length() >= 2UI) {
                    var arg = args[1UI]
                    if (Program.looksLikeUrl(arg)) {
                        remoteUrl = arg
                        if (args.length() >= 3UI) {
                            branch = args[2UI]
                        }
                    } else {
                        branch = arg
                    }
                }
                if (remoteUrl == null) {
                    remoteUrl = Program.urlFromConfig("origin")
                    if (remoteUrl == null) {
                        "push: no URL passed and remote 'origin' not in .git/config".println()
                        return
                    }
                }
                if (branch == null) {
                    var head = HeadReader.read(".git")
                    if (head.detached) {
                        "push: HEAD is detached — pass <branch> explicitly".println()
                        return
                    }
                    branch = head.branch
                }

                var ok = PushClient.push(".git", remoteUrl, branch)
                if (ok) {
                    "Push complete.".println()
                } else {
                    "Push reported failures — see lines above.".println()
                }
            } catch (ex: Exception) {
                ("push: " + ex.message).println()
            }
        }

        private static fun printUsage() {
            "am-git — a small git client written in AmLang".println()
            "".println()
            "Commands:".println()
            "  init [<dir>]                        Scaffold an empty .git/ at <dir> (default cwd)".println()
            "  config [--list | --unset <key> |    Read / write .git/config (INI)".println()
            "    <key> [<value>]]".println()
            "  clone <url> [target-dir]            Clone a remote repository over smart-HTTP".println()
            "  fetch [<url>|<remote-name>]         Fetch refs + objects (defaults from .git/config)".println()
            "  pull [<url>] [<branch>]             Fast-forward-only pull (fetch + advance HEAD)".println()
            "  push [<url>] [<branch>]             Push HEAD or named branch (defaults from .git/config)".println()
            "  add <path>...                       Stage path(s) into .git/index (file or dir)".println()
            "  rm [--cached] <path>...             Unstage; without --cached also delete from disk".println()
            "  mv <source> <destination>           Rename a tracked file (single file only)".println()
            "  status                              Show staged / unstaged / untracked changes".println()
            "  log [-n N]                          Walk commit ancestry from HEAD".println()
            "  branch [<name> | -d <name>]         List / create / delete local branches".println()
            "  tag [<name> [<commit>]] | -d <name> List / create (lightweight) / delete tags".println()
            "  checkout <branch>                   Switch HEAD and the working tree to a branch".println()
            "  merge <branch>                      Merge <branch> into the current branch".println()
            "  merge-base <a> <b>                  Print the lowest common ancestor of two commits".println()
            "  reset [--soft|--mixed|--hard]       Move HEAD (and optionally index / worktree) to <commit>".println()
            "    [<commit>]".println()
            "  rebase <upstream>                   Replay current-branch commits on top of <upstream>".println()
            "  cherry-pick <commit>                Apply <commit>'s changes onto HEAD as a new commit".println()
            "  revert <commit>                     Create a new commit that undoes <commit>".println()
            "  diff [--staged] [--name-only |      Path-level diff (worktree/index/HEAD/two commits)".println()
            "    --name-status] [<a> [<b>]]".println()
            "  show [<commit>]                     Print a commit's metadata + path-level changes".println()
            "  commit -m <message>                 Commit the cwd working tree against HEAD".println()
            "  commit-tree <tree>                  Write a commit object pointing at the given tree".println()
            "    [-p <parent>] -m <msg>".println()
            "  hash-object [-w] <file>             Compute (and optionally write) a blob's SHA-1".println()
            "  write-tree                          Build trees/blobs from cwd, print root tree SHA".println()
            "  head                                Print resolved HEAD (branch / commit / detached)".println()
            "  whoami                              Print author/committer as a commit would record".println()
            "  cat-file (-p|-t) <sha>              Print a loose object's content (-p) or type (-t)".println()
            "  rev-list-objects <new> [<have>]     List reachable SHAs from <new> minus those from <have>".println()
            "  pack-objects <out> <new> [<have>]   Pack reachable objects into a v2 packfile".println()
            "  build-push-body <out> <old> <new> <ref>".println()
            "                                      Build a raw receive-pack request body".println()
            "  auth-header [<user> <pass>]         Print the Authorization header that would be sent".println()
            "  version                             Print version information".println()
            "  help                                Show this help".println()
            "".println()
            "Environment:".println()
            "  AM_GIT_USER_NAME, AM_GIT_USER_EMAIL  Identity used for commit author/committer".println()
            "    (GIT_AUTHOR_NAME / GIT_COMMITTER_NAME etc. also accepted)".println()
            "  AM_GIT_USERNAME, AM_GIT_PASSWORD     HTTP Basic auth credentials for push and".println()
            "                                       cloning private repos (use a PAT for GitHub)".println()
        }
    }
}
