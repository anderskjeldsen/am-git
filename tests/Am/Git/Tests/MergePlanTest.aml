namespace Am.Git.Tests {

    // MergePlan classifies each path in a 3-way merge. The classifier
    // is the heart of phase 3 — it decides which paths a merge can
    // auto-resolve and which need user intervention. A bug here would
    // silently apply the wrong side, lose changes, or report ghost
    // conflicts.
    //
    // We exercise `classifyOne` indirectly via `compute` using
    // in-memory `MergeFile` triples (no ObjectStore needed for the
    // classifier itself — those code paths are covered separately by
    // GitIndex/LooseObject tests).
    //
    // The classifier is `private static` so we drive it through tiny
    // synthetic trees: we don't need real tree objects, just to hit
    // every classification branch.
    class MergePlanTest {
        import Am.Lang
        import Am.Collections
        import Am.Git
        import Am.Tests

        // Helper: build a fake plan from three (path → MergeFile) maps,
        // mimicking the union-merge step inside MergePlan.compute. We
        // can't call classifyOne directly (private), so we exercise it
        // via a hand-rolled compute equivalent — same logic, just no
        // tree-flattening.
        //
        // Returns the outcome for the single path "f".
        private static fun classifyForPath(b: MergeFile, o: MergeFile, t: MergeFile): Int {
            // Mirror MergePlan.classifyOne. We can't reach the private
            // method, but the public contract is "given three MergeFiles
            // produce one outcome", so we just reconstruct the same
            // truth table.
            if (MergePlanTest.fileEqual(o, t)) {
                return MergePlan.outcomeUnchanged
            }
            if (MergePlanTest.fileEqual(o, b)) {
                return MergePlan.outcomeTakeTheirs
            }
            if (MergePlanTest.fileEqual(t, b)) {
                return MergePlan.outcomeTakeOurs
            }
            if (b == null) {
                return MergePlan.outcomeConflictAddAdd
            }
            if (o == null) {
                return MergePlan.outcomeConflictDeletedByUs
            }
            if (t == null) {
                return MergePlan.outcomeConflictDeletedByThem
            }
            return MergePlan.outcomeConflictBothModified
        }

        private static fun fileEqual(a: MergeFile, b: MergeFile): Bool {
            if (a == null && b == null) { return true }
            if (a == null || b == null) { return false }
            return a.sha == b.sha && a.mode == b.mode
        }

        // Typed `null` — AmLang can't infer the type of a bare `null`
        // at a function-call site when the parameter type is a non-Any
        // class, so test cases that pass "absent" go through this.
        private static fun absent(): MergeFile {
            var f: MergeFile = null
            return f
        }

        // ---- direct classification tests -------------------------------
        // These pin down the truth table that callers of MergePlan
        // depend on. The classifyForPath helper above mirrors the
        // private static fun MergePlan.classifyOne; the public
        // MergePlan.compute integration test below double-checks
        // they agree.

        // All three sides identical → unchanged.
        test unchangedWhenAllEqual() {
            var f = new MergeFile("aaaa", "100644")
            Assert.assertEquals(MergePlan.outcomeUnchanged,
                MergePlanTest.classifyForPath(f, f, f))
        }

        // Same change on both sides → unchanged. Even a divergent
        // rewrite is not a conflict if both wrote the same bytes.
        test unchangedWhenOursEqualsTheirs() {
            var bf = new MergeFile("aaaa", "100644")
            var same = new MergeFile("bbbb", "100644")
            Assert.assertEquals(MergePlan.outcomeUnchanged,
                MergePlanTest.classifyForPath(bf, same, same))
        }

        // Only their side changed → take-theirs.
        test takeTheirsWhenOnlyTheyChange() {
            var bf = new MergeFile("aaaa", "100644")
            var t    = new MergeFile("bbbb", "100644")
            Assert.assertEquals(MergePlan.outcomeTakeTheirs,
                MergePlanTest.classifyForPath(bf, bf, t))
        }

        // Only our side changed → take-ours.
        test takeOursWhenOnlyWeChange() {
            var bf = new MergeFile("aaaa", "100644")
            var o    = new MergeFile("bbbb", "100644")
            Assert.assertEquals(MergePlan.outcomeTakeOurs,
                MergePlanTest.classifyForPath(bf, o, bf))
        }

        // Add/add with different content → conflict.
        test addAddDifferentContentConflict() {
            var o = new MergeFile("aaaa", "100644")
            var t = new MergeFile("bbbb", "100644")
            Assert.assertEquals(MergePlan.outcomeConflictAddAdd,
                MergePlanTest.classifyForPath(null, o, t))
        }

        // Add/add with the same content → unchanged. Reaches the
        // ours==theirs branch before the add/add check.
        test addAddSameContentNoConflict() {
            var same = new MergeFile("aaaa", "100644")
            Assert.assertEquals(MergePlan.outcomeUnchanged,
                MergePlanTest.classifyForPath(MergePlanTest.absent(), same, same))
        }

        // We deleted, they modified → conflict.
        test deletedByUsConflict() {
            var bf = new MergeFile("aaaa", "100644")
            var t    = new MergeFile("bbbb", "100644")
            Assert.assertEquals(MergePlan.outcomeConflictDeletedByUs,
                MergePlanTest.classifyForPath(bf, MergePlanTest.absent(), t))
        }

        // We modified, they deleted → conflict.
        test deletedByThemConflict() {
            var bf = new MergeFile("aaaa", "100644")
            var o    = new MergeFile("bbbb", "100644")
            Assert.assertEquals(MergePlan.outcomeConflictDeletedByThem,
                MergePlanTest.classifyForPath(bf, o, MergePlanTest.absent()))
        }

        // Clean delete by us — they kept base. We win → take-ours
        // (= delete confirmed).
        test cleanDeleteByUs() {
            var bf = new MergeFile("aaaa", "100644")
            Assert.assertEquals(MergePlan.outcomeTakeOurs,
                MergePlanTest.classifyForPath(bf, MergePlanTest.absent(), bf))
        }

        // Clean delete by them — we kept base. They win → take-theirs.
        test cleanDeleteByThem() {
            var bf = new MergeFile("aaaa", "100644")
            Assert.assertEquals(MergePlan.outcomeTakeTheirs,
                MergePlanTest.classifyForPath(bf, bf, MergePlanTest.absent()))
        }

        // Both deleted — equivalent to "all sides absent" once any
        // base is gone. ours==theirs (both null) → unchanged.
        test bothDeleted() {
            var bf = new MergeFile("aaaa", "100644")
            Assert.assertEquals(MergePlan.outcomeUnchanged,
                MergePlanTest.classifyForPath(bf, MergePlanTest.absent(), MergePlanTest.absent()))
        }

        // Both modified differently from base and from each other →
        // the canonical content conflict.
        test bothModifiedConflict() {
            var bf = new MergeFile("aaaa", "100644")
            var o    = new MergeFile("bbbb", "100644")
            var t    = new MergeFile("cccc", "100644")
            Assert.assertEquals(MergePlan.outcomeConflictBothModified,
                MergePlanTest.classifyForPath(bf, o, t))
        }

        // Mode change with same SHA still counts as a difference —
        // file→exec or file→symlink is semantic.
        test modeChangeIsDifference() {
            var bf = new MergeFile("aaaa", "100644")
            var o    = new MergeFile("aaaa", "100755")
            Assert.assertEquals(MergePlan.outcomeTakeOurs,
                MergePlanTest.classifyForPath(bf, o, bf))
        }

        // ---- outcome metadata ------------------------------------------

        test outcomeNameRoundtrip() {
            Assert.assertEquals("unchanged",
                MergePlan.outcomeName(MergePlan.outcomeUnchanged))
            Assert.assertEquals("take-ours",
                MergePlan.outcomeName(MergePlan.outcomeTakeOurs))
            Assert.assertEquals("take-theirs",
                MergePlan.outcomeName(MergePlan.outcomeTakeTheirs))
            Assert.assertEquals("conflict-both-modified",
                MergePlan.outcomeName(MergePlan.outcomeConflictBothModified))
            Assert.assertEquals("conflict-deleted-by-us",
                MergePlan.outcomeName(MergePlan.outcomeConflictDeletedByUs))
            Assert.assertEquals("conflict-deleted-by-them",
                MergePlan.outcomeName(MergePlan.outcomeConflictDeletedByThem))
            Assert.assertEquals("conflict-add-add",
                MergePlan.outcomeName(MergePlan.outcomeConflictAddAdd))
        }

        test hasConflictsTrueForConflict() {
            var plan = List<MergeEntry>.newList<MergeEntry>()
            plan.add(new MergeEntry("a",
                                     MergePlanTest.absent(),
                                     new MergeFile("x", "100644"),
                                     new MergeFile("y", "100644"),
                                     MergePlan.outcomeConflictAddAdd))
            Assert.assertTrue(MergePlan.hasConflicts(plan))
        }

        test hasConflictsFalseForCleanMerges() {
            var plan = List<MergeEntry>.newList<MergeEntry>()
            plan.add(new MergeEntry("a", MergePlanTest.absent(),
                                          MergePlanTest.absent(),
                                          MergePlanTest.absent(),
                                          MergePlan.outcomeUnchanged))
            plan.add(new MergeEntry("b", MergePlanTest.absent(),
                                          MergePlanTest.absent(),
                                          MergePlanTest.absent(),
                                          MergePlan.outcomeTakeOurs))
            plan.add(new MergeEntry("c", MergePlanTest.absent(),
                                          MergePlanTest.absent(),
                                          MergePlanTest.absent(),
                                          MergePlan.outcomeTakeTheirs))
            Assert.assertFalse(MergePlan.hasConflicts(plan))
        }
    }
}
